  stripeAccountId String?
  lastTestedAt    DateTime?
  lastTestStatus  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
