  restaurantId String   @unique
  legalName    String   @default("") // registered company / sole-trader name
  taxId        String   @default("") // VAT number / tax code
  taxIdType    String   @default("") // Stripe tax_id type, e.g. eu_vat, gb_vat, us_ein
  billingEmail String   @default("")
  addressLine1 String   @default("")
  addressLine2 String   @default("")
  city         String   @default("")
  state        String   @default("")
  postalCode   String   @default("")
  country      String   @default("") // ISO-3166 alpha-2
  sdiCode      String   @default("") // Italy e-invoicing recipient code
  pec          String   @default("") // Italy certified email
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
