generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id                          String    @id @default(cuid())
  name                        String
  slug                        String    @unique
  slogan                      String?
  description                 String?
  phone                       String?
  email                       String?
  address                     String?
  city                        String?
  state                       String?
  zip                         String?
  country                     String    @default("US")
  timezone                    String    @default("America/New_York")
  // Display format for hours throughout the admin UI and customer-facing
  // surfaces. "12h" → "9:00 PM"; "24h" → "21:00". Stored hours data is
  // always 24-hour HH:MM in the DB regardless — this only controls
  // RENDERING. Default 24h is the regional convention for most of our
  // launch markets (Canada, EU); North-American restaurants typically
  // flip this to 12h on day-one.
  hoursFormat                 String    @default("24h")
  // Kitchen workflow mode:
  //   "simple"   → GloriaFood-style. Kitchen only sees Accept + Reject.
  //                Once accepted, the order stays in "In Progress" with
  //                no further state transitions until end-of-day. The
  //                customer is notified at Accept and again at the
  //                scheduled-ready time (or after a buffer). This is
  //                the DEFAULT — busy restaurants don't have time to
  //                click Preparing/Ready/Complete on every order.
  //   "tracking" → Full state machine. Kitchen clicks Preparing → Ready
  //                → (Out for delivery) → Complete. Each click fires
  //                a separate customer notification. Best when a
  //                restaurant wants to give precise status updates.
  //
  // Toggle is per-restaurant on the admin Services & Hours page.
  // Default = "simple" to match GloriaFood's well-tested model.
  kitchenWorkflowMode         String    @default("simple")
  // PrintNode backup printer enabled? Default false. Now that the
  // Direct LAN printer (native app, mDNS auto-discovery) is the main
  // printing path, PrintNode is opt-in only — restaurants on Windows
  // browsers or with unusual network setups can enable it as a
  // backup. When false, the PrintNode setup UI is hidden from the
  // kitchen settings to keep the default experience clean.
  printNodeEnabled            Boolean   @default(false)
  cuisineType                 String?
  logoUrl                     String?
  /// Dedicated receipt-header logo (Vercel Blob URL). When set, the
  /// "store_logo" section prints/renders it at the top of the CUSTOMER
  /// receipt (HTML preview + email immediately; physical Star print after
  /// the Android app picks up image-line support). Separate from logoUrl on
  /// purpose: thermal printing wants a high-contrast image, which is often
  /// not the colored web logo. Luigi 2026-06-11.
  receiptLogoUrl              String?
  bannerUrl                   String?
  /// Optional per-restaurant favicon (square icon, recommended 350x350) shown
  /// in the browser tab on the customer ordering page. Falls back to the
  /// platform default when null. Nullable + on the small Restaurant table, so
  /// no hot-path/scale concern.
  faviconUrl                  String?
  isActive                    Boolean   @default(true)
  acceptsPickup               Boolean   @default(true)
  acceptsDelivery             Boolean   @default(false)
  acceptsDineIn               Boolean   @default(false)
  acceptsCatering             Boolean   @default(false)
  acceptsTakeOut              Boolean   @default(false)
  acceptsReservations         Boolean   @default(false)
  /// Per-service pause timestamps. When non-null AND in the future,
  /// the corresponding service is paused — customers see a banner +
  /// the order button for that service is blocked. When the timestamp
  /// passes (or is null) the service auto-resumes on the next page
  /// load — no cron required. Luigi 2026-06-01 GloriaFood-parity:
  /// kitchen needs a "pause for the rest of the day" / "pause for 1
  /// hour" button when they're slammed, so they can stop new orders
  /// without disabling the service globally.
  pickupPausedUntil           DateTime?
  deliveryPausedUntil         DateTime?
  dineInPausedUntil           DateTime?
  cateringPausedUntil         DateTime?
  takeOutPausedUntil          DateTime?
  reservationsPausedUntil     DateTime?
  serviceSettings             String? // JSON: per-service { displayName, description, estimatedTime }
  /// Minimum advance notice (in HOURS) required for catering orders.
  /// When the cart contains any item flagged `isCatering` — or any item
  /// in a category flagged `isCatering` — the customer MUST schedule the
  /// order at least this many hours into the future. ASAP orders are
  /// blocked. Enforced both client-side (the schedule picker's earliest
  /// slot is now+cateringNoticeHours) AND server-side (/api/orders POST
  /// rejects any catering cart without a sufficiently-future scheduledFor).
  /// Default 24h matches the most common catering shop convention.
  cateringNoticeHours         Int       @default(24)
  minimumOrder                Float     @default(0)
  deliveryFee                 Float     @default(0)
  /// Delivery advanced setting (GloriaFood-parity, Luigi 2026-06-04): when
  /// true, customers may place a delivery order even if their address falls
  /// OUTSIDE every configured delivery zone. Default false = block out-of-zone
  /// orders at checkout (the restaurant must opt in to accept them).
  acceptOutsideZoneOrders     Boolean   @default(false)
  /// Customizable delivery-address form (GloriaFood-style). JSON map of
  /// { fieldKey: { show, required } } over the 9 canonical fields. NULL = use
  /// the default preset (Street/City/Postcode required, Apartment optional).
  /// Single source of truth: src/lib/delivery-address-fields.ts. Luigi 2026-06-04.
  deliveryAddressConfig       Json?
  estimatedPickup             Int       @default(20)
  estimatedDelivery           Int       @default(45)
  taxRate                     Float     @default(0)
  /// Whether the customer-side cart shows the tip selector. False
  /// suppresses the entire tip block (no "0% / 10% / 15% / custom"
  /// row) and the order POST clamps any client-sent tip to 0 so a
  /// tampered client can't inject one. Default true to preserve the
  /// historical behaviour for restaurants that haven't touched this.
  tipsEnabled                 Boolean   @default(true)
  /// Whether the customer ordering page shows the magnifying-glass
  /// menu search bar above the category pills. Default true to
  /// preserve the historical "always-on" behaviour (Luigi 2026-05-31).
  /// When false the entire search row is omitted — clients use the
  /// category pills to navigate, GloriaFood style. Toggled by the
  /// owner from /admin/service-fees > Customer ordering page.
  showCustomerMenuSearch      Boolean   @default(true)
  /// ISO 4217 lowercase currency code (matches Stripe's expectation:
  /// "usd", "cad", "eur", "gbp", "aud", etc.). Drives the customer
  /// price formatting, Stripe PaymentIntent currency, PayPal Order
  /// currency, kitchen receipt symbol, and email totals. Default
  /// "usd" so existing restaurants don't change behaviour silently.
  currency                    String    @default("usd")
  /// Vercel-Blob URL of a custom new-order ring sound uploaded by the
  /// owner via /admin/profile. When non-null the KDS Sound Settings
  /// modal surfaces it as a third selectable option (alongside
  /// GloriaFood Ding + Classic Bell) — the staff member at the
  /// terminal still picks which sound plays so a custom track doesn't
  /// override their personal preference. Null = no custom sound on
  /// file, the picker only shows the two built-ins.
  kitchenAlertSoundUrl        String?
  /// Minutes between selectable scheduling slots for customer orders.
  /// GloriaFood ships 15-minute intervals; we let owners pick from
  /// 10/15/20/30/60. Without this the schedule picker is a free-form
  /// HTML datetime-local input and a customer can schedule "3:02 PM"
  /// which doesn't fit any kitchen workflow. Italian beta tester
  /// reported 2026-05-31. Default 15 to match GloriaFood's default.
  scheduledOrderInterval      Int       @default(15)
  /// Pre-order ("order for later") advance-time limits per service, mirroring
  /// the reservation min-notice / max-advance controls. Min lead = how soon
  /// the earliest schedulable slot can be (in MINUTES; 0 = only bounded by the
  /// prep estimate). Max advance = how many DAYS ahead a customer can schedule
  /// (0 = no limit). Applied client-side (date/time picker bounds) AND
  /// server-side (order validation). Fabrizio report cmq14gy64.
  pickupMinLeadMinutes        Int       @default(0)
  pickupMaxAdvanceDays        Int       @default(0)
  deliveryMinLeadMinutes      Int       @default(0)
  deliveryMaxAdvanceDays      Int       @default(0)
  dineInMinLeadMinutes        Int       @default(0)
  dineInMaxAdvanceDays        Int       @default(0)
  /// Master switch: may customers request a specific fulfillment time at all?
  /// false → the schedule picker is hidden (ASAP only), unless a catering /
  /// closed-now rule forces scheduling. GloriaFood "Allow clients to request
  /// a specific fulfillment time".
  allowScheduledOrders        Boolean   @default(true)
  /// Hide the "as soon as possible" option — every order must be scheduled
  /// for a future slot. Only effective when allowScheduledOrders is true.
  /// GloriaFood "Hide 'as soon as possible' (allow only scheduled orders)".
  requireScheduledOrders      Boolean   @default(false)
  /// Show each service's estimated time (e.g. "Pickup · 20 min") on the ORDERING PAGE
  /// service buttons. Default true (current behaviour). Off → those times are hidden on the
  /// order page but still shown at checkout / in the zone estimate. Fabrizio 2026-06-25.
  showServiceTimesOnOrderPage Boolean   @default(true)
  /// Show the house/civic number AFTER the street name (e.g. "Via Roma 12") instead of
  /// before it ("12 Via Roma") when an address is picked from autocomplete. Default false
  /// (number-first, North-American). Per-restaurant so it never flips an existing store's
  /// format. Fabrizio 2026-06-25.
  addressNumberAfterStreet    Boolean   @default(false)
  /// Ordering-page promotional POPUP (shown once per browser session on /order/[slug]). JSON:
  /// { enabled, imageUrl?, title?, body?, buttonLabel?, buttonUrl? }. Null = no popup. The owner
  /// configures it in the admin Profile page. Additive + nullable. Fabrizio 2026-06-25.
  orderingPopup               Json?
  /// Whether the customer's email is mandatory on the checkout form.
  /// Default true so receipts can be sent; an owner who only wants
  /// SMS notification can flip this off and require phone instead.
  /// Validation gate lives in the checkout form + order POST.
  requireCustomerEmail        Boolean   @default(true)
  /// Whether the customer's phone number is mandatory on checkout.
  /// Default true because the kitchen needs to call customers about
  /// delivery / pickup hand-offs.
  requireCustomerPhone        Boolean   @default(true)
  /// Auto phone-call alert (report cmpxeph4l): when on, a new order left
  /// unaccepted for ~90s triggers an automated voice call to the
  /// restaurant's phone so an unattended tablet doesn't drop the order.
  /// Requires the platform Twilio voice creds + a restaurant phone number.
  autoCallOnNewOrder          Boolean   @default(false)
  /// Kitchen device alarm: vibrate alongside the ring on a new order. Default
  /// true (ring + vibrate); false = ring only. Read by the FCM push + the
  /// alarm-state poll, then honored by the native OrderAlarmService. Luigi
  /// 2026-06-16 (Fabrizio: let the restaurant choose ring+vibrate vs ring-only).
  kitchenVibrate              Boolean   @default(true)
  /// Kitchen order TILE: for DELIVERY orders, lead the tile with the customer
  /// NAME instead of the street address, so staff can identify an order by name
  /// when a customer calls. Default false = address (current). Fabrizio 2026-06-21.
  kitchenDeliveryShowName     Boolean   @default(false)
  /// Delivery/catering tile ALSO shows the street address under the name (only
  /// applies when kitchenDeliveryShowName is on) → "Name — then Address".
  /// Additive (default false) so an existing name/address preference is kept.
  /// Luigi 2026-06-22.
  kitchenDeliveryShowBoth     Boolean   @default(false)
  /// Kitchen order DETAIL: show each dish's menu CATEGORY under its name (helps
  /// when the same dish name appears in different categories, e.g. Japanese
  /// menus). Default false = off. Fabrizio 2026-06-21.
  kitchenShowItemCategory     Boolean   @default(false)
  /// Optional alternate number for the nearly-missed-order auto-call (e.g. the
  /// owner's cell). Null/blank ⇒ fall back to the public `phone`.
  alertPhone                  String?
  // Stripe Connect (Layer C — restaurant collects payments from customers)
  stripeAccountId             String?
  stripeAccountStatus         String?   @default("not_connected")
  stripeChargesEnabled        Boolean   @default(false)
  stripePayoutsEnabled        Boolean   @default(false)

  // PayPal direct charges (Layer C alternative — same model as Stripe Connect:
  // restaurant owns the merchant account, money lands directly in their PayPal
  // balance, platform never touches funds). Credentials encrypted via encrypt.ts.
  // Owner pastes their REST app client ID + secret from
  // https://developer.paypal.com/dashboard/applications into our admin; we
  // never see the raw secret again after the initial encrypt.
  paypalAccountStatus String?   @default("not_connected") // not_connected | connected | error
  paypalEnvironment   String?   @default("live") // sandbox | live
  paypalClientIdEnc   String?
  paypalClientIdIv    String?
  paypalClientIdTag   String?
  paypalSecretEnc     String?
  paypalSecretIv      String?
  paypalSecretTag     String?
  paypalMerchantEmail String? // shown in admin so owner sees which account is wired
  paypalWebhookId     String? // webhook ID registered on PayPal for this restaurant
  paypalConnectedAt   DateTime?

  // FREE-plan order cap tracking. Every restaurant on the FREE plan
  // (subscriptionStatus="free" AND no active paid add-ons) is limited
  // to 100 orders/month. See src/lib/order-cap.ts — `currentMonthOrderCount`
  // increments on every /api/orders POST; `currentMonthResetAt` is the
  // start of the NEXT calendar month. When `now >= currentMonthResetAt`
  // we lazy-reset the counter to 0 and bump resetAt forward. No cron
  // needed — rollover happens organically on the first order of a new
  // month. Restaurants with any active paid add-on are exempt
  // (counter still increments for analytics but isn't enforced).
  currentMonthOrderCount Int       @default(0)
  currentMonthResetAt    DateTime?
  // Order-cap owner-notification guards (Luigi 2026-06-16). capWarn80SentAt: set
  // when the "approaching your limit" email goes out at 80, reset to null on the
  // monthly rollover so it fires once per month. capBlockAlertSentAt: set when
  // the "you're losing orders" alert fires at the cap, rate-limited ~3h. Both
  // are nullable timestamps on this small table — cheap, no hot-table bloat.
  capWarn80SentAt        DateTime?
  capBlockAlertSentAt    DateTime?

  /// JSON array of accepted payment methods chosen by the owner.
  /// Allowed values today: "cash" | "card_in_person" | "online_card" | "paypal".
  /// Required for publishing — owner must pick at least one. When the
  /// array includes "online_card", the Stripe Connect step also becomes
  /// required to publish (you can't promise online card and have no
  /// processor wired up). Same constraint applies to "paypal" — must
  /// have a connected PayPal account to publish with paypal in the list.
  /// Empty array means "not yet configured".
  paymentMethods String @default("[]")

  // Platform subscription (Layer B — restaurant pays you monthly via Stripe Checkout)
  subscriptionPlanId     String?
  // Deprecated: trialEndsAt was used during the trial-as-default era. We
  // no longer create trials — every restaurant lands on the FREE plan
  // directly. Column kept (nullable, unused on new rows) so we don't
  // need a destructive migration to drop it.
  trialEndsAt            DateTime?
  // Status values: "free" (default — every new restaurant lands here),
  // "active" (paid plan), "past_due" | "cancelled" | "incomplete" |
  // "expired" (Stripe-driven). "trialing" is no longer set on new
  // restaurants but may exist on legacy rows — treated equivalently to
  // "free" everywhere it's checked (see GRANTING_STATUSES in
  // src/lib/entitlements.ts).
  subscriptionStatus     String    @default("free")
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  /// Dunning / failed-payment grace (Luigi 2026-06-15). A failed charge does
  /// NOT cut service — it starts a grace clock; paid features stay ON until
  /// graceEndsAt, then drop to the free tier (ordering always keeps working).
  /// dunningStartedAt anchors the "day X of N" countdown; lastDunnedOn is the
  /// YYYY-MM-DD of the last daily reminder (one nudge/day idempotency). Null =
  /// billing healthy. See src/lib/entitlements.ts + /api/cron/dunning.
  dunningStartedAt       DateTime?
  graceEndsAt            DateTime?
  lastDunnedOn           String?
  reviewLink             String?
  infoContent            String? // JSON for info page custom CTAs etc
  themeSettings          String? // JSON for customer-facing website theme
  /// JSON for the hosted marketing site (gated on the Sales Optimized
  /// Website add-on). Controls section visibility, hero copy overrides,
  /// custom CTAs, and up to 2 user-defined sections. All BASE content
  /// (menu, hours, address, logo) still flows from the canonical
  /// restaurant fields — this column only stores layout/display choices.
  /// Null = use defaults from the canonical fields (the current behavior).
  /// See src/lib/hosted-site-settings.ts for the parsed shape.
  hostedSiteSettings     String?
  lat                    Float? // geocoded restaurant latitude
  lng                    Float? // geocoded restaurant longitude
  mapProvider            String    @default("leaflet") // "leaflet" | "google"
  googleMapsApiKey       String? // only used when mapProvider = "google"
  autoAcceptOrders       Boolean   @default(false)
  /// Currently-active kitchen-display session token. Rotated on every
  /// /kitchen login so only the newest device's JWT matches what's
  /// in the DB — older devices' JWTs become stale and the kitchen
  /// API/heartbeat rejects them with 401 → they redirect to login.
  /// GloriaFood-parity single-active-session enforcement
  /// (Luigi 2026-06-02). Null = no kitchen device has ever logged in,
  /// in which case the JWT verification is bypassed for back-compat
  /// with sessions minted before this column existed.
  kitchenSessionToken    String?
  defaultLanguage        String    @default("en")
  // What the restaurant calls its VIP-special recipients in the announcement
  // email ("As a {vipMemberLabel} at …"). Owner-chosen brand term (e.g. "VIP
  // member", "Teacher", "Club member"); null → localized default "VIP member".
  vipMemberLabel         String?
  // ── Reward Dollars (store-credit wallet, Program 3). Per-restaurant opt-in +
  //    fully configurable: each restaurant chooses to earn-by-auto, earn-by-grant,
  //    both, or neither. Customer-facing NAME is renameable (default localized
  //    "Reward Dollars"). Money is Float to match every other money column. ──────
  rewardsEnabled         Boolean   @default(false) // master on/off for the whole feature
  rewardLabelSingular    String? // e.g. "Reward Dollar" — null → localized default
  rewardLabelPlural      String? // e.g. "Reward Dollars"
  rewardEarnEnabled      Boolean   @default(false) // auto-earn on completed orders
  rewardEarnMode         String    @default("percent") // "percent" | "per_dollar"
  rewardEarnPercent      Float     @default(0) // % of (subtotal−discount) earned back
  rewardEarnPerDollar    Float     @default(0) // $ earned per $1 of (subtotal−discount)
  rewardRedeemEnabled    Boolean   @default(false) // customers may spend at checkout
  rewardMinRedeemBalance Float     @default(0) // min balance before any redemption
  rewardMaxRedeemPercent Float     @default(100) // cap % of an order coverable by credit
  rewardSignupBonus      Float     @default(0) // credit granted on account creation
  rewardExpiryDays       Int       @default(0) // 0 = never (stored; not enforced v1)
  // Show a "sign up to start earning {rewardName}" banner to LOGGED-OUT customers
  // on the order page (guests can't earn/spend). Owner opt-in. Luigi 2026-06-30.
  rewardSignupBannerEnabled Boolean @default(false)
  socialLinks            String? // JSON: { instagram, facebook, tiktok, x, youtube, linkedin, pinterest, snapchat, threads, whatsapp, yelp, googleBusiness, tripadvisor, website }
  marketingTier          String    @default("free") // "free" | "social_basic" | "social_pro" | "social_managed" — gates AI-post / scheduling features
  /// Marketing & tracking integrations the OWNER configures for their own
  /// ordering site (Integrations page). The restaurant is the data controller
  /// for this tracking — injected on /order/<slug> when set. Validated to the
  /// provider's ID shape before storage. Luigi 2026-06-17.
  facebookPixelId        String? // numeric Meta Pixel ID
  googleAnalyticsId      String? // GA4 Measurement ID, "G-XXXXXXXXXX"

  // Domain routing: "subdomain" → <sub>.<PLATFORM_DOMAIN>, "customDomain" → bring-your-own.
  // slug stays internal-stable (used by /order/[slug] paths and order references);
  // subdomain is the marketing-changeable label the customer sees in their address bar.
  subdomain           String?   @unique
  customDomain        String?   @unique
  customDomainStatus  String    @default("none") // none | pending | verifying | verified | error
  customDomainAddedAt DateTime?
  customDomainError   String?

  /// LOCAL calendar day (stored as a UTC-midnight @db.Date of the local day
  /// key) the end-of-day digest email was last SENT for. Written by the
  /// closing-time sweep and the morning catch-up; makes the two crons
  /// idempotent so a restaurant never gets the same day's report twice.
  /// Reseller report cmq8gfpxn, Luigi 2026-06-11.
  lastEodDigestDate DateTime? @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptionPlan       SubscriptionPlan?         @relation(fields: [subscriptionPlanId], references: [id])
  users                  User[]
  menuCategories         MenuCategory[]
  menuItems              MenuItem[]
  menus                  Menu[]
  modifierGroups         ModifierGroup[]
  orders                 Order[]
  orderRatings           OrderRating[]
  customers              Customer[]
  coupons                Coupon[]
  deliveryZones          DeliveryZone[]
  openingHours           OpeningHours[]
  holidays               RestaurantHoliday[]
  receiptTemplates       ReceiptTemplate[]
  promotions             Promotion[]
  printerSettings        PrinterSettings?
  autopilotCampaigns     AutopilotCampaign[]
  autopilotSteps         AutopilotStep[]
  smartLinks             SmartLink[]
  marketingAssets        MarketingAsset[]
  paymentProvider        PaymentProvider?
  billingProfile         RestaurantBillingProfile?
  printLogs              PrintLog[]
  reservationSettings    ReservationSettings?
  reservationTables      ReservationTable[]
  reservations           Reservation[]
  notificationRecipients NotificationRecipient[]
  serviceFees            ServiceFee[]
  subscriptionInvoices   SubscriptionInvoice[]
  // GloriaFood-parity marketing suite (2026-05-29)
  autopilotState         AutopilotState?
  kickstarterState       KickstarterState?
  cartSessions           CartSession[]
  prospectImports        ProspectImport[]
  customerCoupons        CustomerCoupon[]
  customerGroups         CustomerGroup[]
  rewardAccounts         RewardAccount[]
  vipSchedules           VipSchedule[]
  rewardEarnRules        RewardEarnRule[]

  // Reseller Partner Program — set at restaurant creation when the signup
  // carried a ?ref=<referralCode> from an approved reseller. Nullable: most
  // restaurants are direct, not reseller-sourced. Only superadmin can reassign
  // (support cases). On reseller deletion → SetNull so the restaurant stays.
  resellerProfileId String?
  resellerProfile   ResellerProfile?        @relation(fields: [resellerProfileId], references: [id], onDelete: SetNull)
  restaurantAccess  RestaurantAccess[]
  commissions       CommissionTransaction[]

  // Multi-location: a child Restaurant points its parentRestaurantId at the
  // brand's "primary" Restaurant. Nullable — existing restaurants stay
  // top-level (parent = null). Each location bills/operates independently;
  // the parent link only drives UX (location switcher, "add another location"
  // button in the admin sidebar).
  parentRestaurantId String?
  parentRestaurant   Restaurant?  @relation("Locations", fields: [parentRestaurantId], references: [id], onDelete: SetNull)
  childLocations     Restaurant[] @relation("Locations")
  /// Multi-location menu inheritance. Only meaningful for child locations
  /// (parentRestaurantId != null). When true, this location SERVES the
  /// parent's menu — both the customer order page and the admin's menu
  /// editor read from the parent's MenuCategory/MenuItem rows. When false,
  /// the location has its own independent menu (and the admin can edit
  /// it freely). Defaults to true so new locations onboarded via invite
  /// inherit by default — the brand sets up the menu once, every new
  /// location adopts it. Toggling false copies the parent's menu rows
  /// into this location so the owner has something to edit.
  useBrandMenu       Boolean      @default(true)
  /// Per-option inheritance for a CHILD location (parentRestaurantId != null),
  /// per Luigi's multi-location spec (2026-06-13): from the child account the
  /// owner toggles, INDEPENDENTLY per setting, whether the PARENT controls it or
  /// the child sets it locally — or flips "everything from parent" at once.
  /// Sparse JSON map { settingKey: true } where true = "inherit from parent".
  /// Keys today: "hours" | "zones" | "availability" (menu keeps its dedicated
  /// useBrandMenu boolean above for backward-compat; the UI presents them
  /// together). A missing key / null column = NOT inheriting, so every EXISTING
  /// location keeps operating independently — no behaviour change on migration.
  /// LIVE inheritance (the child reads the parent's current value on each load),
  /// distinct from the one-time creation snapshot in src/lib/location-inheritance.ts.
  /// Resolver: src/lib/inherited-settings.ts.
  inheritedSettings  Json?
  /// Per-option LOCK for a CHILD location, set by the BRAND PARENT (Luigi's
  /// franchise-control spec, 2026-06-14). A sparse JSON map { settingKey: true }
  /// where true = the child may NOT change this setting themselves — the parent
  /// controls it. Keys mirror the inheritable settings: "menu" | "hours" |
  /// "zones" | "availability". Missing key / null column = UNLOCKED (the child
  /// may toggle it), so every EXISTING location is unaffected on migration. The
  /// child's inheritance + menu endpoints reject changes to a locked setting;
  /// the child UI greys it out as "Managed by your brand".
  /// Resolver: src/lib/inherited-settings.ts.
  lockedSettings     Json?

  // Customer-side email toggles (single set per restaurant)
  customerEmailPickupReady   Boolean @default(true)
  customerEmailDeliveryReady Boolean @default(true)
  customerEmailDineInReady   Boolean @default(false)
  customerEmailOrderRejected Boolean @default(true)
  customerEmailOrderConfirm  Boolean @default(true)

  // Publishing / setup state (Phase 1 of the GloriaFood-style redesign).
  // publishedAt is null until the owner finishes required setup and clicks
  // "Publish" — only then does the Legacy Website widget render and the
  // /order/<slug> page accept real customers. Existing restaurants get this
  // field auto-populated by scripts/migrate-to-free-plan.ts so nothing breaks.
  publishedAt          DateTime?
  ownerEmailVerifiedAt DateTime?
  /// Opaque public ID used by the widget embed snippet so the embed URL
  /// doesn't leak the slug. Generated lazily on first publish (Phase 3).
  widgetPublicId       String?   @unique
  /// First time the embedded widget.js script fired its install heartbeat
  /// (a one-time GET ping when the script loads on any third-party site).
  /// Drives the "Install the Legacy Website widget" setup-checklist step
  /// so it auto-completes when the restaurant pastes the snippet onto
  /// their actual site, no manual confirm required.
  widgetInstalledAt    DateTime?

  addOns                 RestaurantAddOn[]
  kitchenDevices         KitchenDevice[]
  locationInvites        LocationInvite[]
  marketplaceListing     MarketplaceListing?
  marketplaceSettlements MarketplaceSettlement[]
  shipdayConfig          ShipdayConfig?

  // Reports — see "REPORTS" section at bottom of file. 4-year retention.
  reportDailySnapshots ReportDailySnapshot[]
  websiteVisits        WebsiteVisit[]
  websiteFunnelEvents  WebsiteFunnelEvent[]
  menuItemViews        MenuItemView[]
  connectivityEvents   ConnectivityEvent[]
  sandbox              SandboxRestaurant?

  @@index([resellerProfileId])
  @@index([parentRestaurantId])
  @@index([publishedAt])
  // Dunning cron scans only restaurants currently in a grace period; the
  // in-grace set is tiny, so indexing graceEndsAt keeps the daily sweep off
  // a full-table scan as the platform grows.
  @@index([graceEndsAt])
}

/// Brand → location invite tokens. When a multi-location brand owner wants
/// to add a new location, they generate one of these rows (via the brand
/// admin dashboard). The recipient receives an email with a signup link
/// containing `?invite=<token>`. Completing signup creates a fresh
/// Restaurant + User, parented under the brand. Tokens are single-use.
model LocationInvite {
  id                   String     @id @default(cuid())
  brandId              String
  brand                Restaurant @relation(fields: [brandId], references: [id], onDelete: Cascade)
  token                String     @unique
  email                String? // pre-fill on signup form (optional, owner's choice)
  suggestedName        String? // suggested location name (e.g. "Brooklyn Branch")
  createdByUserId      String // userId of the brand admin who created the invite
  acceptedAt           DateTime?
  acceptedRestaurantId String? // restaurant created by accepting this invite
  expiresAt            DateTime // 30 days from creation by default
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([brandId])
  @@index([token])
  @@index([expiresAt])
}

/// Anonymous "import-to-try" sandbox: a temp Restaurant provisioned by the public
/// /import flow (no account) so a visitor can see their real GloriaFood menu live
/// before signing up. claimToken attaches this exact restaurant to a new account
/// at signup (go live with zero re-import). Unclaimed rows are cleaned up after
/// expiresAt by a cron. Side table (sparse) so we never add sandbox columns to
/// the hot Restaurant row. (Luigi 2026-06-21 — import-to-try growth wedge.)
model SandboxRestaurant {
  id              String     @id @default(cuid())
  restaurantId    String     @unique
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  email           String
  sourceLabel     String? // parsed GloriaFood UID/host — support/debug only
  ipHash          String? // hashed client IP for abuse review (never the raw IP)
  claimToken      String     @unique
  expiresAt       DateTime // unclaimed sandboxes are deleted after this
  claimedAt       DateTime?
  claimedByUserId String?
  createdAt       DateTime   @default(now())

  @@index([email])
  @@index([claimToken])
  @@index([expiresAt])
}

/// Tracks each kitchen PWA install (or kitchen-staff session) that has
/// checked in via the heartbeat endpoint. The publishing checklist's
/// "Order-taking app connected" step is satisfied when at least one row
/// exists for the restaurant whose lastSeenAt is within the freshness
/// window. The device "id" is a stable hash the kitchen page sends from
/// localStorage on every poll — not an authoritative identity, just a
/// best-effort presence signal.
model KitchenDevice {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  /// Stable random ID generated by the kitchen page on first load and
  /// persisted in localStorage. Used to dedupe the same device polling
  /// repeatedly so we update one row instead of inserting many.
  deviceHash   String
  /// Free-form label the owner sets in the admin (e.g. "Front counter").
  label        String?
  userAgent    String?
  lastSeenAt   DateTime   @default(now())
  firstSeenAt  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, deviceHash])
  @@index([restaurantId])
  @@index([lastSeenAt])
}

model NotificationRecipient {
  id            String  @id @default(cuid())
  restaurantId  String
  email         String
  name          String?
  isActive      Boolean @default(true)
  emailLanguage String  @default("en")

  // Confirmation events
  deliveryConfirmed         Boolean @default(true)
  pickupConfirmed           Boolean @default(true)
  tableReservationConfirmed Boolean @default(true)
  orderAheadConfirmed       Boolean @default(true)
  dineInConfirmed           Boolean @default(true)

  // Operational events
  orderPlaced    Boolean @default(true)
  orderAccepted  Boolean @default(true)
  orderRejected  Boolean @default(true)
  orderCanceled  Boolean @default(true)
  orderMissed    Boolean @default(true)
  orderNotPlaced Boolean @default(true)

  // System events
  lowBattery       Boolean @default(true)
  badInternet      Boolean @default(true)
  endOfDayReport   Boolean @default(true)
  endOfMonthReport Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model SubscriptionPlan {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  price       Float // monthly USD price; cents on Stripe side
  interval    String  @default("month") // month | year
  description String?
  features    String // JSON-encoded array of feature bullets
  isActive    Boolean @default(true)

  // Stripe sync state — Product is reused across price changes; Prices are
  // immutable so any `price` edit creates a NEW stripePriceId. Old Prices
  // stay archived (active=false on Stripe) so existing subscribers keep
  // their grandfathered rate until we explicitly migrate them.
  stripeProductId String?   @unique
  stripePriceId   String?   @unique
  syncStatus      String    @default("not_synced") // not_synced | syncing | synced | error
  syncError       String?
  syncedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  restaurants Restaurant[]
}

// Audit trail of every invoice Stripe sends for a restaurant's platform
// subscription. Webhook handlers upsert into this table on invoice.paid /
// invoice.payment_failed events. Keyed by stripeInvoiceId for idempotency.
model SubscriptionInvoice {
  id                   String    @id @default(cuid())
  restaurantId         String
  stripeInvoiceId      String    @unique
  stripeSubscriptionId String?
  amountPaid           Int // in cents
  amountDue            Int       @default(0) // in cents
  currency             String    @default("usd")
  status               String // paid | open | uncollectible | void | draft
  paidAt               DateTime?
  periodStart          DateTime?
  periodEnd            DateTime?
  hostedInvoiceUrl     String?
  invoicePdfUrl        String?
  receiptUrl           String?
  attemptCount         Int       @default(0)
  createdAt            DateTime  @default(now())

  // Refund/dispute tracking — read by the commission engine. Initially 0/false
  // on creation; updated by charge.refunded / charge.dispute.created webhook
  // handlers when the underlying charge is reversed.
  amountRefundedCents Int     @default(0)
  disputed            Boolean @default(false)

  restaurant Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  commission CommissionTransaction?

  @@index([restaurantId])
  @@index([stripeSubscriptionId])
}

// Idempotency log — every Stripe webhook event we've successfully processed.
// On retry, we look up by stripeEventId and short-circuit.
model StripeWebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  eventType     String
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?
  status        String    @default("received") // received | processed | failed | ignored
  errorMessage  String?

  @@index([eventType])
  @@index([receivedAt])
}

// Idempotency log for PayPal webhooks. Same shape as StripeWebhookEvent —
// PayPal retries on failure for up to 25 attempts over 3 days, so dedup
// by event id is non-negotiable.
model PaypalWebhookEvent {
  id            String    @id @default(cuid())
  paypalEventId String    @unique
  eventType     String
  resourceId    String? // PayPal order / authorization / capture id, when present
  receivedAt    DateTime  @default(now())
  processedAt   DateTime?
  status        String    @default("received") // received | processed | failed | ignored
  errorMessage  String?

  @@index([eventType])
  @@index([receivedAt])
  @@index([resourceId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("restaurant_admin")
  restaurantId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Phase 1 of the signup-redesign: set when the owner clicks the verify
  /// link from their welcome email. Required for publishing (Phase 3 wires
  /// the actual gate; this field exists earlier so we can mark existing
  /// restaurants as already-verified via the migration script).
  emailVerifiedAt  DateTime?
  emailVerifyToken String?   @unique

  restaurant       Restaurant?          @relation(fields: [restaurantId], references: [id])
  resetTokens      PasswordResetToken[]
  resellerProfile  ResellerProfile? // present only on reseller_partner users
  restaurantAccess RestaurantAccess[] // non-owner restaurant grants
}

// Singleton row holding platform-wide settings (Resend API key, etc.).
// Only the super admin can read/write. Secrets are AES-256-GCM encrypted at rest.
model PlatformSettings {
  id                     String   @id @default("singleton")
  // Resend (email) — encrypted key, plain envelope (iv + auth tag)
  resendApiKeyEnc        String?
  resendApiKeyIv         String?
  resendApiKeyTag        String?
  emailFrom              String? // e.g. "Fee Free Ordering <hello@yourdomain.com>"
  // Stripe — secret key + webhook secret encrypted at rest. Publishable key
  // is stored plain (safe to expose to clients). When any of these are null
  // we fall back to the matching env var (STRIPE_SECRET_KEY etc.).
  stripeMode             String? // "test" | "live"
  stripeEnabled          Boolean  @default(false)
  stripePublishableKey   String?
  stripeSecretKeyEnc     String?
  stripeSecretKeyIv      String?
  stripeSecretKeyTag     String?
  stripeWebhookSecretEnc String?
  stripeWebhookSecretIv  String?
  stripeWebhookSecretTag String?
  /// Platform-wide Google Maps key (Luigi 2026-06-13): set ONCE in superadmin
  /// and every restaurant uses it for maps + Places autocomplete + Distance
  /// Matrix — no per-restaurant Google Cloud setup. A restaurant's OWN
  /// googleMapsApiKey still wins (cost offload). Stored PLAIN, not encrypted:
  /// a Maps key is protected by HTTP-referrer + API restrictions, not secrecy,
  /// and the browser half is necessarily exposed client-side anyway.
  googleMapsApiKey       String?
  updatedAt              DateTime @updatedAt
  updatedBy              String?
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// A named menu version owned by a restaurant (e.g. "Main", "Summer",
/// "Winter"). Exactly ONE menu per restaurant is active (isActive=true) at a
/// time — that's the one customers see. Others are drafts/archived that the
/// owner can edit off-line and schedule to go live. Categories belong to a
/// menu via MenuCategory.menuId. Multi-menu manager Phase 0. Luigi 2026-06-05.
model Menu {
  id                  String    @id @default(cuid())
  restaurantId        String
  name                String    @default("Main Menu")
  /// The single live menu for the restaurant. App logic guarantees one active.
  isActive            Boolean   @default(false)
  /// When set + in the future, a cron flips this menu live at that moment
  /// (deactivating whichever menu was active). Cleared once published.
  scheduledActivateAt DateTime?
  /// Last time this menu went live (audit / "published on" display).
  publishedAt         DateTime?
  /// Recurring daily-window scheduling (Luigi 2026-06-12, report cmpxdzr9y
  /// follow-up). When availableFrom/To are set, this menu is the live one
  /// ONLY during these days/hours (restaurant tz); a menu with no window is
  /// the all-hours default. Mirrors MenuItem's availability columns. Save-
  /// time validation guarantees the active menus cover every open hour.
  availableDays       String? // JSON: [0,1,2,3,4,5,6] — null = every day
  availableFrom       String? // "HH:MM" — null = no time restriction (default menu)
  availableTo         String? // "HH:MM"
  isArchived          Boolean   @default(false)
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categories MenuCategory[]

  @@index([restaurantId, isActive])
  @@index([scheduledActivateAt])
}

model MenuCategory {
  id               String    @id @default(cuid())
  restaurantId     String
  /// Which menu version this category belongs to. Nullable during the Phase 0
  /// migration; backfilled to the restaurant's default "Main Menu". The
  /// customer page reads only the ACTIVE menu's categories.
  menuId           String?
  name             String
  description      String?
  imageUrl         String?
  /// Exclude every item in this category from Reward Dollars EARNING (e.g. a
  /// "Gift Cards" category). Per-item rewardEarnExcluded can override. Luigi 2026-06-30.
  rewardEarnExcluded Boolean @default(false)
  isActive         Boolean   @default(true)
  /// LEGACY visibility toggle. Superseded by the visibility* model below
  /// (Luigi 2026-06-12, GloriaFood-style rebuild). Migrated to
  /// visibilityMode="hide_from_menu"; kept so old rows / un-migrated data
  /// still hide. New code reads visibilityMode first, falls back to isHidden.
  isHidden         Boolean   @default(false)
  /// GloriaFood-style scheduled visibility. null = always visible. One of:
  ///   "hide_from_menu"  → hidden from customers entirely
  ///   "hide_until"      → hidden now, auto-appears at visibleUntil
  ///   "show_only_from"  → visible ONLY on visibleDays during visibleFrom–visibleTo (recurring weekly)
  ///   "show_from_until" → visible ONLY between visibleStartDate and visibleEndDate (one-off period)
  /// Mirrors MenuItem's visibility columns. Restaurant timezone applies.
  visibilityMode   String?
  visibleUntil     DateTime? // hide_until: hidden until this moment
  visibleStartDate DateTime? // show_from_until: visible from
  visibleEndDate   DateTime? // show_from_until: visible until
  visibleDays      String? // show_only_from: JSON [0..6] (null = every day)
  visibleFrom      String? // show_only_from: "HH:MM"
  visibleTo        String? // show_only_from: "HH:MM"
  /// When true, every item in this category is treated as catering —
  /// cart with any of them must be scheduled ≥ Restaurant.cateringNoticeHours
  /// in advance (ASAP is blocked). Per-item MenuItem.isCatering ORs with
  /// this flag, so an owner can either tag a whole category or sprinkle
  /// catering items into a regular category.
  isCatering       Boolean   @default(false)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  menu           Menu?           @relation(fields: [menuId], references: [id])
  menuItems      MenuItem[]
  modifierGroups ModifierGroup[]

  @@index([restaurantId, isActive])
  @@index([menuId])
  @@index([restaurantId, rewardEarnExcluded])
}

/// Background photo-import queue (Luigi/Fabrizio 2026-06-16). A GloriaFood
/// import enqueues one row per item/category image instead of downloading them
/// inline — GloriaFood's CDN bans bursts, so a single request can't pull 200+
/// photos (24 land, the rest get blocked). The `import-menu-images` cron drips
/// them in (low concurrency + retries across runs) until every photo is
/// re-hosted on Vercel Blob, then deletes the row. A SIDE-TABLE — NOT nullable
/// columns on the hot MenuItem — per the scaling rule; only ever holds PENDING
/// images so it stays tiny.
model PendingMenuImage {
  id             String    @id @default(cuid())
  restaurantId   String
  /// Exactly one target is set (the item OR the category the photo belongs to).
  menuItemId     String?
  menuCategoryId String?
  /// GloriaFood CDN URL to fetch + re-host on Vercel Blob.
  sourceUrl      String
  attempts       Int       @default(0)
  lastTriedAt    DateTime?
  /// Last failure reason (HTTP status or error message) — visibility into why a
  /// photo isn't landing yet, so stuck rows can be diagnosed from the DB.
  lastError      String?
  createdAt      DateTime  @default(now())

  @@index([attempts, createdAt])
  @@index([restaurantId])
}

model MenuItem {
  id               String    @id @default(cuid())
  restaurantId     String
  categoryId       String
  /// Stable identity that survives across menu versions: when a menu is
  /// duplicated, the copy's items keep the SAME lineageId as their source.
  /// Lets promotions (which reference item ids) be remapped old→new on
  /// publish, and lets reports group an item across versions. Backfilled to
  /// the item's own id for pre-existing items. Multi-menu Phase 0.
  lineageId        String?
  name             String
  description      String?
  price            Float
  imageUrl         String?
  isAvailable      Boolean   @default(true)
  isFeatured       Boolean   @default(false)
  isSoldOut        Boolean   @default(false)
  /// LEGACY visibility toggle — superseded by the visibility* model below
  /// (GloriaFood-style rebuild, Luigi 2026-06-12). Migrated to
  /// visibilityMode="hide_from_menu"; new code reads visibilityMode first.
  isHidden         Boolean   @default(false)
  /// GloriaFood-style scheduled visibility (same model as MenuCategory).
  /// null = always visible. One of: "hide_from_menu" | "hide_until" |
  /// "show_only_from" | "show_from_until". See MenuCategory for field meanings.
  visibilityMode   String?
  visibleUntil     DateTime?
  visibleStartDate DateTime?
  visibleEndDate   DateTime?
  visibleDays      String?
  visibleFrom      String?
  visibleTo        String?
  hasVariants      Boolean   @default(false)
  forPickup        Boolean   @default(true)
  forDelivery      Boolean   @default(true)
  /// Per-item catering flag — opts THIS item into the catering-notice
  /// rule (see Restaurant.cateringNoticeHours). ORs with the parent
  /// category's `isCatering` flag, so either path tags the item.
  /// Cart with any catering item forces schedule-for-later mode with
  /// earliest slot = now + cateringNoticeHours.
  isCatering       Boolean   @default(false)
  availableDays    String? // JSON: [0,1,2,3,4,5,6] — null = all days
  availableFrom    String? // "HH:MM"
  availableTo      String? // "HH:MM"
  /// What happens OUTSIDE the availability window (Luigi 2026-06-11, reseller
  /// report cmpxec829 — Cloudwaitress-style): null/"hide" = item disappears
  /// from the customer menu (legacy); "show" = item stays VISIBLE with an
  /// "available …" note but can't be added to the cart. Server-side order
  /// validation rejects out-of-window items in BOTH modes. Nullable so the
  /// hot MenuItem table needs no rewrite/backfill.
  availabilityMode String?
  /// FULFILMENT TIME (Luigi 2026-06-12, Phase 2). When set, the item is
  /// VISIBLE per its visibility settings, but can only be ORDERED FOR these
  /// days/times — e.g. a Tuesday special shows all week, greys out for ASAP,
  /// and is orderable only when the order's fulfilment slot lands on Tuesday.
  /// Independent of `visible*` (show/hide) and the legacy availableDays. null
  /// = no fulfilment restriction. Restaurant timezone applies. Server rejects
  /// an order whose effective fulfilment time is outside the window.
  fulfilDays       String? // JSON [0..6] — null = any day
  fulfilFrom       String? // "HH:MM"
  fulfilTo         String? // "HH:MM"
  sortOrder        Int       @default(0)
  calories         Int?
  allergens        String?
  /// Exclude this item from Reward Dollars EARNING (e.g. gift cards — don't earn
  /// store credit for buying store credit). Item-level override of its category's
  /// flag. Spending is unaffected. Luigi 2026-06-30.
  rewardEarnExcluded Boolean @default(false)
  pizzaConfig      String? // JSON: PizzaConfig — marks item as a pizza builder item
  /// JSON: ComboConfig — marks this item as a COMBO (e.g. "2-Pizza Combo",
  /// "Pizza + Wings"). Defines ordered slots, each with an eligible item/
  /// category pool, min/max picks, and optional per-item upcharges. When set,
  /// tapping the item opens the combo composer instead of adding directly;
  /// pizza-builder items inside a slot open the full pizza builder. The combo
  /// is a single menu line at this item's price + any premium upcharges.
  /// Multi-pizza combos as a first-class menu item. Luigi 2026-06-05.
  comboConfig      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  category       MenuCategory    @relation(fields: [categoryId], references: [id])
  variants       ItemVariant[]
  modifierGroups ModifierGroup[]
  orderItems     OrderItem[]
  // Reports — MenuItemView log for Menu Insights "Views" column.
  views          MenuItemView[]

  @@index([restaurantId, isAvailable])
  @@index([categoryId, sortOrder])
  @@index([restaurantId, rewardEarnExcluded])
}

// Represents a size/variation (e.g., Small / Medium / Large)
model ItemVariant {
  id         String   @id @default(cuid())
  menuItemId String
  name       String // e.g., "Small (6 Slice - 10 inch)"
  price      Float
  sortOrder  Int      @default(0)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  menuItem       MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroups ModifierGroup[]
}

// Modifier groups can be:
// - item-level:    menuItemId set, categoryId null, restaurantId null
// - variant-level: variantId set, menuItemId set
// - category-level: categoryId set, menuItemId null
// - library (reusable): restaurantId set, menuItemId null, categoryId null
model ModifierGroup {
  id               String   @id @default(cuid())
  restaurantId     String? // null = item-scoped, set = library group
  menuItemId       String?
  variantId        String?
  categoryId       String?
  name             String
  description      String?
  required         Boolean  @default(false)
  minSelect        Int      @default(0)
  maxSelect        Int      @default(1)
  maxPerOption     Int      @default(1) // how many times same option can be picked
  isHidden         Boolean  @default(false)
  sortOrder        Int      @default(0)
  libraryGroupId   String? // if attached from a library group (points to the source library ModifierGroup id)
  /// Whether the group can be split half/half on a pizza item. Owners
  /// flip this for groups whose options can physically be applied
  /// per-half (toppings, sauces, cheeses, drizzles, etc.) and leave it
  /// off for groups that don't make sense to split (crust, cook level,
  /// side drinks, deposits). When true AND the pizza's master Half/Half
  /// toggle is on, the customer-side Pizza Builder renders the group
  /// with whole/split UI; otherwise it renders as a normal option grid.
  /// Default false — owner explicitly enables via the modifier group
  /// library editor.
  supportsHalfHalf Boolean  @default(false)
  /// Pizza role tag: "crust" | "sauce" | "cheese" | "topping" | null. When a
  /// role has ANY tagged group, the matching pizza picker (Crust/Sauce/Cheese
  /// dropdown or the Topping multi-select) lists ONLY tagged groups instead of
  /// every modifier in the library (Fabrizio 2026-06-21). null = untagged →
  /// shows everywhere (legacy behaviour). Owners set it in the modifier group
  /// editor. Authoring-only; not read on the customer side.
  pizzaRole        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurant Restaurant?      @relation(fields: [restaurantId], references: [id])
  menuItem   MenuItem?        @relation(fields: [menuItemId], references: [id])
  variant    ItemVariant?     @relation(fields: [variantId], references: [id])
  category   MenuCategory?    @relation(fields: [categoryId], references: [id])
  options    ModifierOption[]
}

model ModifierOption {
  id              String   @id @default(cuid())
  modifierGroupId String
  name            String
  priceAdjustment Float    @default(0)
  isDefault       Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  modifierGroup ModifierGroup       @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemMods OrderItemModifier[]
}

model Order {
  id                    String    @id @default(cuid())
  restaurantId          String
  customerId            String?
  orderNumber           String
  status                String    @default("pending")
  type                  String    @default("pickup")
  customerName          String
  customerEmail         String?
  customerPhone         String?
  deliveryAddress       String?
  deliveryCity          String?
  deliveryZip           String?
  /// Structured per-field delivery address (customizable form). JSON blob of
  /// { fieldKey: value } so we don't add sparse columns to this hot table. The
  /// flat deliveryAddress/City/Zip above are still composed from this for
  /// receipts/kitchen/dispatch. src/lib/delivery-address-fields.ts. 2026-06-04.
  deliveryAddressData   Json?
  /// True when this delivery order's address geocoded OUTSIDE every active
  /// delivery zone but was accepted anyway (restaurant opted in via
  /// acceptOutsideZoneOrders). Drives a "may be outside your regular zone"
  /// note to kitchen staff. Non-null boolean = cheap on this hot table. 2026-06-04.
  outsideDeliveryZone   Boolean   @default(false)
  notes                 String?
  couponId              String?
  couponDiscount        Float     @default(0)
  promoDiscount         Float     @default(0)
  subtotal              Float
  taxAmount             Float     @default(0)
  deliveryFee           Float     @default(0)
  tip                   Float     @default(0)
  total                 Float
  // Reward Dollars (store credit) applied as PARTIAL PAYMENT. `total` stays the
  // full amount (tax/receipts/refunds intact); the online charge = total −
  // creditApplied. Default 0 → existing orders unaffected. Luigi 2026-06-27.
  creditApplied         Float     @default(0)
  paymentMethod         String    @default("cash")
  paymentStatus         String    @default("pending")
  paymentIntentId       String? // Stripe PaymentIntent id (when paymentMethod = "card")
  // PayPal lineage (when paymentMethod = "paypal"). We capture all three
  // ids so we can refund/void against the right resource. PayPal's flow:
  //   order → authorize → captures[]. We treat capture like Stripe's
  //   payment_intent.succeeded — only then is `paymentStatus = paid`.
  paypalOrderId         String?
  paypalAuthorizationId String?
  paypalCaptureId       String?
  refundStatus          String? // null | "pending" | "refunded" | "partial" | "failed"
  /// Cumulative amount refunded to the customer (major currency units, e.g.
  /// euros) via the manual Refund action. null/0 = nothing refunded yet.
  /// A partial refund leaves the order paymentStatus "partially_refunded";
  /// a full refund (refundedAmount >= total) sets paymentStatus "refunded".
  refundedAmount        Float?
  /// Set when the order has been "released" to the kitchen + customer
  /// (i.e. notifications fired, kitchen display picks it up). For cash
  /// orders this is set immediately in /api/orders POST. For online-card
  /// orders this stays null until the payment_intent.succeeded webhook
  /// fires — preventing the kitchen from starting cook before payment
  /// clears. Kitchen GET filters on `notifiedAt IS NOT NULL`.
  notifiedAt            DateTime?

  /// Closed-when-placed handling (Luigi 2026-05-30).
  ///
  /// When the restaurant is closed at order-create time, the customer is
  /// forced to "schedule for later" with min slot = next opening time.
  /// We stamp `placedWhileClosed=true` AND set `alertAt` to the
  /// restaurant's next opening moment so the kitchen alert+countdown
  /// fires when the restaurant actually opens (not at order-create time
  /// in the middle of the night) — with a longer 15-minute countdown
  /// instead of the standard 3-minute, because staff may arrive a few
  /// minutes after open.
  ///
  /// `alertAt` is null for normal ASAP orders during open hours
  /// (alert fires immediately — same as before this column existed).
  /// Kitchen display: orders with alertAt > now appear silently in
  /// the pending tab but DON'T trigger the ring sound or countdown
  /// until now reaches alertAt.
  placedWhileClosed Boolean   @default(false)
  alertAt           DateTime?
  /// When the "nearly-missed order" auto phone-call was placed to the
  /// restaurant (report cmpxeph4l). Set once so the every-minute cron never
  /// double-calls for the same order. Null = no call placed yet.
  alertCallAt       DateTime?

  /// Marketplace channel attribution. True when the customer came from
  /// our /marketplace browse page (detected via ?from=marketplace at
  /// order creation). Drives:
  ///   - The smart-billing rollup (counts toward the monthly cap math)
  ///   - The "saved vs UberEats" tracker (we don't compute savings for
  ///     direct orders — those would have happened on the restaurant's
  ///     own widget, not UberEats)
  ///   - Reports showing marketplace vs direct revenue split
  viaMarketplace Boolean @default(false)

  /// Snapshot of what UberEats / DoorDash would have charged THIS restaurant
  /// in commission on this specific order (30% of order total, in cents).
  /// Frozen at order time so historical reports stay accurate even if our
  /// commission-comparison rate changes later. Null for non-marketplace
  /// orders — direct orders weren't "competing" with UberEats.
  savedVsUberEatsCents Int?

  /// Has this order's marketplace counter (MarketplaceListing.currentMonthOrders
  /// + currentMonthRevenue) already been applied? Used by the decrement-on-
  /// cancel logic to stay idempotent: when an order is rejected/cancelled, we
  /// only subtract from the counters if the original create-time increment
  /// actually happened. Prevents double-decrement on repeat status flips.
  /// Only ever true on orders with viaMarketplace=true.
  marketplaceCounterApplied Boolean   @default(false)
  /// Marketing Studio per-link attribution (Luigi 2026-06-10). `smartLinkId` is
  /// the SmartLink this order is attributed to (resolved from the matched
  /// visit's refCode at create). `smartLinkCounterApplied` is the write-once
  /// idempotency claim — mirrors marketplaceCounterApplied — so a link's
  /// order/revenue counters bump EXACTLY once even on retries / status flips.
  /// Both write-only at create; off the customer read hot path.
  smartLinkId               String?
  smartLinkCounterApplied   Boolean   @default(false)
  scheduledFor              DateTime?
  estimatedReady            DateTime?
  acceptedAt                DateTime?
  /// Set the first time this order's ticket is printed — by the web auto-print,
  /// the native background-print service, or a manual print. Atomic claim
  /// (updateMany where kitchenPrintedAt:null) makes printing EXACTLY-ONCE across
  /// the web app, the native background service, app restarts, and multiple
  /// devices, so the app-closed background print and the app-open web print can
  /// never double-print the same ticket. Luigi 2026-06-22.
  kitchenPrintedAt          DateTime?
  rejectedAt                DateTime?
  rejectionReason           String?
  completedAt               DateTime?
  preparationTime           Int?
  deliveryZoneId            String?
  deliveryEstimatedMinutes  Int?
  appliedServiceFees        String? // JSON: [{ name, amount }] frozen at order time
  /// Snapshot of every promotion that fired for THIS order, frozen at
  /// order-create time so the receipt + confirmation + email can show
  /// "10% off — JULY SPECIAL  −$4.54" even months later when the
  /// underlying promo has been edited or deleted. JSON shape:
  ///   [{ promoId, name, type, discount, couponCode? }, ...]
  /// Free-delivery promos appear here with discount=0 (the savings are
  /// realised by zeroing deliveryFee, not by reducing the subtotal).
  /// Null on orders created before this field shipped (back-compat).
  appliedPromos             String? // JSON

  /// ShipDay dispatch tracking. Set when an order is dispatched to the
  /// ShipDay third-party driver pool — populated by the dispatch call
  /// in PATCH /api/orders/[id] (order acceptance). Status is updated
  /// asynchronously by the ShipDay webhook at /api/webhooks/shipday as
  /// drivers pick up + deliver. Null on orders that were never sent to
  /// ShipDay (in-house delivery, pickup, dine-in).
  shipdayOrderId String?
  shipdayStatus  String? // assigned | picked_up | delivered | failed | cancelled
  dispatchedAt   DateTime?

  /// Geocoded coordinates of `deliveryAddress`. Populated by a background
  /// reverse-geocode at order creation (Nominatim for Leaflet restaurants,
  /// Google Geocoding API when the restaurant has mapProvider="google").
  /// Null on pickup/dine-in orders and on rows created before the
  /// geocoding job shipped. Powers /admin/reports/online-ordering/heatmap.
  /// Backfill is optional — historical orders without coords just don't
  /// appear in the heatmap, which is acceptable.
  deliveryLat Float?
  deliveryLng Float?

  /// Marketing channel attribution. Set at order creation from the
  /// inbound `?utm_source=` / `?ref=` / Referer header. Values come from
  /// a small enum kept in `src/lib/reports/channels.ts` to keep the
  /// Website Visits + Sales reports' "by channel" breakdown stable:
  ///   "direct" | "marketplace" | "email" | "organic" | "paid_ads"
  ///   | "social_media" | "referral" | "affiliate" | "internal" | null
  /// Null = unknown (rendered as "Direct" in reports for back-compat).
  /// Note: `viaMarketplace` Boolean is the legacy single-source flag — it
  /// stays for billing rollup compatibility; `channel` is the new
  /// multi-value field reports read from.
  channel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// When set, this order has been dismissed from the kitchen display
  /// (via the "Clear orders" or "Clear complete" buttons). Tracked
  /// server-side so it's identical across every device that opens the
  /// kitchen — log in on a phone after dismissing on the tablet and
  /// you see the same list (Luigi 2026-06-02 GloriaFood-parity follow-
  /// up). The order itself isn't deleted — admin reports + customer
  /// status pages still see it. Just hidden from the kitchen list.
  clearedFromKitchenAt  DateTime?
  /// PER-TAB kitchen clear (Luigi 2026-06-04). Each kitchen tab clears
  /// independently — the SAME order can be dismissed from the All tab while
  /// staying visible in In Progress / Complete, and vice-versa. The In
  /// Progress tab has no clear button, so it has no flag and always shows
  /// its orders. Legacy clearedFromKitchenAt (above) still hides globally
  /// for orders cleared before this change.
  clearedFromAllAt      DateTime?
  clearedFromCompleteAt DateTime?
  /// Set when kitchen staff MANUALLY move an order to Ready/Complete in Simple
  /// mode. Such orders leave "In Progress" and appear in "Complete" immediately
  /// (GloriaFood-style), instead of waiting for the end-of-day auto-complete.
  /// Null = not manually moved → keeps the existing auto end-of-day behavior.
  /// Luigi 2026-06-07.
  manuallyClearedAt     DateTime?

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  customer     Customer?     @relation(fields: [customerId], references: [id])
  coupon       Coupon?       @relation(fields: [couponId], references: [id])
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  items        OrderItem[]
  rating       OrderRating?

  @@index([restaurantId, createdAt])
  @@index([restaurantId, status])
  @@index([restaurantId, orderNumber])
  // Reports: filter by channel within a date range. Used by the
  // /admin/reports/sales/summary "by payment type / by channel" pivot.
  @@index([restaurantId, channel, createdAt])
  // Reports: filter completed orders within a date range. The default
  // (restaurantId, createdAt) index covers the date scan but Postgres
  // still has to filter status afterward; this composite makes the
  // dashboard "completed orders last 7 days" query a true index-only.
  @@index([restaurantId, status, createdAt])
  // Kitchen alarm-state poll (every ~4s per device): the auto-accept ring query
  // and the background-print "toPrint" query both seek (restaurantId, "accepted")
  // and filter/sort by notifiedAt. Without notifiedAt in the index Postgres scans
  // the whole per-restaurant accepted set every poll. Luigi 2026-06-22.
  @@index([restaurantId, status, notifiedAt])
}

/// Customer-submitted rating for a completed order. One row per order
/// at most (orderId is unique). Surfaced on the status page once the
/// order reaches `completed`; the customer taps 👍 / 👎 and (on 👎)
/// optionally types a short comment. Restaurants see aggregate scores
/// in the admin reports.
///
/// Schema designed to extend later: add `dimension` rows (food / speed /
/// packaging) without changing the read query if needed.
model OrderRating {
  id           String   @id @default(cuid())
  orderId      String   @unique
  restaurantId String
  /// 1 = thumbs up, -1 = thumbs down. We deliberately don't use a
  /// 1-5 star scale at launch — thumbs are higher-completion in
  /// post-meal contexts and let us avoid 3-star "indifferent" noise.
  /// Stored as Int so we can extend to stars later without migrating.
  score        Int
  comment      String?
  createdAt    DateTime @default(now())

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  menuItemId  String?
  variantId   String?
  variantName String?
  name        String
  price       Float
  quantity    Int
  notes       String?
  subtotal    Float
  createdAt   DateTime @default(now())

  // ── Meal-bundle line item (Promo Types 8 + 13) ──────────────────────
  //
  // When a customer completes a meal bundle (e.g. "Family Pack: 1 Pizza
  // + 2 Sides + 1 Dessert for $25"), the entire bundle is persisted as
  // ONE OrderItem (the parent / bundle wrapper) with `bundleItems` set
  // to the JSON array of the child picks. Kitchen displays the bundle
  // as a grouped block; the receipt prints the parent line + indented
  // children. The fixed bundle price lives on the parent's `price` and
  // `subtotal` fields; child entries here carry their menu metadata
  // (name, modifiers) for fulfilment only — no pricing.
  //
  // Shape (TypeScript):
  //   { menuItemId: string; variantId?: string; name: string;
  //     variantName?: string;
  //     modifiers?: { name: string; priceAdjustment?: number }[];
  //     notes?: string }[]
  //
  // Null for non-bundle items (all order items pre-2026-05-29).
  bundleItems Json?

  order     Order               @relation(fields: [orderId], references: [id])
  menuItem  MenuItem?           @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  modifiers OrderItemModifier[]
}

model OrderItemModifier {
  id               String  @id @default(cuid())
  orderItemId      String
  modifierOptionId String? // nullable so deleting a modifier group doesn't break order history
  name             String
  priceAdjustment  Float   @default(0)

  orderItem      OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption ModifierOption? @relation(fields: [modifierOptionId], references: [id], onDelete: SetNull)
}

model Customer {
  id                     String    @id @default(cuid())
  restaurantId           String
  name                   String
  email                  String?
  phone                  String?
  address                String?
  notes                  String?
  // Per-restaurant signup credentials. Null = guest-order row that never
  // signed up. Set = customer has a per-restaurant account on this
  // restaurant (separate from the marketplace-wide CustomerAccount).
  // See src/lib/restaurant-customer-session.ts for the auth flow.
  passwordHash           String?
  emailVerifiedAt        DateTime?
  emailVerifyToken       String?
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  lastLoginAt            DateTime?
  // Chain identity for multi-location restaurants. When a customer signs
  // up at any restaurant in a chain (parent or any child), we generate
  // a chainCustomerId and create a Customer row at EVERY restaurant in
  // the chain, all sharing the same chainCustomerId + passwordHash. The
  // customer's one set of credentials then authenticates at any
  // location in the chain. Null for accounts at standalone restaurants.
  chainCustomerId        String?
  /// Customer's marketing-email consent ON THIS RESTAURANT
  /// (GDPR/CASL-style opt-in). Set true when the customer ticked
  /// "Yes, I'd like marketing communications from this restaurant"
  /// at checkout. Can be flipped back to false from their account
  /// profile or via the email unsubscribe link. Reseller scope:
  /// per-restaurant — a customer opted-in at Restaurant A is NOT
  /// auto-opted-in at Restaurant B in the same marketplace.
  /// (Luigi/Fabrizio 2026-06-02 GloriaFood-parity.)
  marketingConsent       Boolean   @default(false)
  /// When the marketingConsent field was last updated. Used for
  /// audit trails / "show me when this customer opted in" + lets
  /// us prove consent if a customer complains.
  marketingConsentAt     DateTime?
  totalOrders            Int       @default(0)
  totalSpent             Float     @default(0)
  /// Timestamp of this customer's most recent order at this restaurant.
  /// Maintained by the order-create webhook. Powers:
  ///   - Reports → Clients dashboard ("returning vs new" cohort split)
  ///   - List View → Clients sort-by-recency
  ///   - Marketing → re-engagement campaigns (lapsed-customer filter)
  /// Null for Customer rows created before this field shipped (back-
  /// compat); the lazy backfill happens the next time they order.
  lastOrderAt            DateTime?
  /// Link to the global CustomerAccount (if the customer has signed up
  /// for an account). Multiple Customer rows (one per restaurant they've
  /// ordered from) can point at the same CustomerAccount — that's the
  /// "ordered from 5 different marketplace restaurants but one identity"
  /// case. Null for guest checkouts that never converted to an account.
  customerAccountId      String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  restaurant        Restaurant                  @relation(fields: [restaurantId], references: [id])
  customerAccount   CustomerAccount?            @relation(fields: [customerAccountId], references: [id])
  orders            Order[]
  addresses         RestaurantCustomerAddress[]
  assignedCoupons   Coupon[]                    @relation("CouponAssignedCustomer")
  customerCoupons   CustomerCoupon[]
  groupMemberships  CustomerGroupMember[]
  vipSpecialTargets CustomerGroupPromotion[]
  rewardAccounts    RewardAccount[]
  vipSchedules      VipSchedule[]

  @@index([restaurantId])
  @@index([restaurantId, email])
  // Account-phone uniqueness check at signup filters on (restaurantId, phone).
  @@index([restaurantId, phone])
  @@index([customerAccountId])
  @@index([chainCustomerId])
  @@index([emailVerifyToken])
  @@index([passwordResetToken])
}

/// Marketplace-wide customer identity. One row per signup email, shared
/// across every restaurant the customer orders from. Stores the auth
/// credential (passwordHash) + profile fields that aren't restaurant-specific.
/// Per-restaurant order history attribution lives on Customer (above) —
/// CustomerAccount is the user-facing "my account" entity.
model CustomerAccount {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  /// Set when email verification succeeds. Used to gate features that
  /// require a confirmed inbox (saved cards, certain notifications).
  emailVerifiedAt  DateTime?
  /// One-time verification token. Generated on signup + on "resend
  /// verification" requests. Consumed by GET /api/customer/verify-email
  /// which flips emailVerifiedAt and clears this back to null. Indexed
  /// unique so lookups by token are O(1).
  emailVerifyToken String?   @unique
  name             String?
  phone            String?
  /// Last time the user successfully signed in. Helps surface stale
  /// accounts + power "your last login" UX.
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  addresses           CustomerAddress[]
  customers           Customer[]
  passwordResetTokens CustomerPasswordResetToken[]

  @@index([email])
}

/// Customer-side password reset token. Separate from `PasswordResetToken`
/// (which is for restaurant-owner `User` accounts) because Customer auth
/// is a distinct identity layer with its own login at /account/login.
/// Single-use, expires in 1 hour. Cascades on account deletion.
model CustomerPasswordResetToken {
  id                String    @id @default(cuid())
  token             String    @unique
  customerAccountId String
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime  @default(now())

  customerAccount CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@index([customerAccountId])
}

/// Saved delivery addresses on a customer's account. Up to a reasonable
/// number per user (no hard cap in schema; UI enforces). isDefault flags
/// the one we prefill at checkout.
model CustomerAddress {
  id                String   @id @default(cuid())
  customerAccountId String
  /// Human label like "Home", "Work" — optional.
  label             String?
  street            String
  city              String
  state             String?
  zip               String?
  country           String   @default("CA")
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())

  customerAccount CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@index([customerAccountId])
}

/// Per-restaurant Customer address book — the same shape as
/// CustomerAddress (marketplace) but keyed on Customer (per-restaurant)
/// since the two account systems are intentionally separate. Lets a
/// signed-in customer save Home/Work addresses and pick from them at
/// checkout instead of retyping every time.
///
/// Audit 2026-05-30: Toast / Uber / DoorDash / Skip / Grubhub / Square
/// all support this; it's one of the biggest mobile-conversion wins.
model RestaurantCustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  label      String?
  street     String
  city       String
  state      String?
  zip        String?
  country    String   @default("CA")
  /// Pin-confirmed delivery coordinates (set via the address-book map pin /
  /// autocomplete). When present, checkout uses these instead of re-geocoding
  /// the typed street, so a saved address delivers to the exact spot. Luigi 2026-06-30.
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Coupon {
  id            String    @id @default(cuid())
  restaurantId  String
  code          String
  description   String?
  discountType  String    @default("percentage")
  discountValue Float
  minimumOrder  Float     @default(0)
  maxUses       Int?
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  // Personal coupon assignment. When set, this coupon is ONLY redeemable
  // by the specified customer (gated at order-create time). Null = open-
  // redeem (anyone with the code can use it — the legacy behaviour).
  // Used by the admin "Assign coupon to customer" action on the
  // customer detail page.
  customerId    String?
  customer      Customer? @relation("CouponAssignedCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  /// Scope of this coupon:
  ///   "location" — only valid at the owning restaurant (default; matches
  ///                existing single-location behavior)
  ///   "brand"    — valid at the owning restaurant AND every child location
  ///                under it. Only meaningful when the owning restaurant is
  ///                a brand parent. The order POST in /api/orders also
  ///                checks the parent's brand-scoped coupons.
  scope         String    @default("location")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]

  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
  @@index([customerId])
  // Order POST evaluates personally-assigned coupons by filtering on
  // BOTH customerId AND isActive. Composite index lets Postgres satisfy
  // the filter without a separate scan. Added 2026-05-28 during the
  // pre-launch scale sweep.
  @@index([customerId, isActive])
}

model Promotion {
  id              String    @id @default(cuid())
  restaurantId    String
  name            String
  description     String?
  promotionType   String    @default("percentage_off")
  isActive        Boolean   @default(true)
  stackingRule    String    @default("standard")
  orderType       String    @default("both")
  customerType    String    @default("any")
  minimumOrder    Float     @default(0)
  rules           String    @default("{}")
  daysOfWeek      String?
  startsAt        DateTime?
  endsAt          DateTime?
  /// Hour-of-day USABILITY window (separate from daysOfWeek visibility).
  /// Per Fabrizio's 2026-05-28 feedback: a "lunch promo" should be
  /// VISIBLE all day (so customers can pre-order tomorrow's lunch) but
  /// only USABLE at lunch hours (e.g. 12-15). Stored as minutes-since-
  /// midnight 0–1440, both inclusive on start, exclusive on end. NULL
  /// on either side = no time constraint (24/7 within the daysOfWeek).
  usableHourStart Int? // 0..1440 (e.g. 720 = 12:00 PM)
  usableHourEnd   Int? // 0..1440 (e.g. 900 = 15:00)
  /// When true, the promo renders as a top-of-page banner on the
  /// customer ordering page (/order/[slug]) so it's impossible to miss
  /// — like GloriaFood's promo cards. When false, it's still applied
  /// at checkout but doesn't get prime real estate. Owners choose per
  /// promo; defaults to true for new promos.
  showOnBanner    Boolean   @default(true)
  /// Banner display copy override. When NULL, we render the promo's
  /// `name` + `description`. When set, the owner gets a tighter
  /// banner-only headline (e.g. "20% off lunch — today only!").
  bannerHeadline  String?
  usageLimit      Int?
  usedCount       Int       @default(0)
  autoApply       Boolean   @default(true)
  couponCode      String?
  /// Scope of this promotion. Same semantics as Coupon.scope above —
  ///   "location" → only applies at the owning restaurant (default)
  ///   "brand"    → applies at the owning restaurant AND every child
  ///                location under it. The order POST in /api/orders
  ///                evaluates both location-scoped and parent-brand-scoped
  ///                active promos for each cart.
  scope           String    @default("location")
  /// Acquisition CHANNEL this promo applies to (Luigi 2026-06-09):
  ///   "website"     → only the restaurant's own ordering page (default)
  ///   "marketplace" → only customers who arrived via the marketplace
  ///                   (from=marketplace / Order.viaMarketplace)
  ///   "both"        → applies on both channels
  /// The marketplace customer base is distinct from the website's, so an owner
  /// can run separate offers per channel (incl. a separate marketplace
  /// first-buy). Default "website" = opt-in for the marketplace, matching
  /// "if not selected, it won't extend to the marketplace". The promo editor
  /// only shows the picker when the restaurant is actually listed on the
  /// marketplace (isOnMarketplace). Evaluated for EVERY promo type, incl.
  /// Kickstarter/Autopilot pre-made promos.
  channel         String    @default("website")

  // ── GloriaFood-parity marketing suite (2026-05-29) ───────────────────
  //
  // Pre-made promos are auto-generated by Kickstarter + Autopilot
  // campaigns and listed under /admin/promotions Pre-made tab. The
  // owning campaign's enable/disable cascades to its child promos.
  //
  //   campaignRef       = "autopilot_2nd_order" | "autopilot_reengage_winN" |
  //                       "autopilot_cart_recovery" | "kickstarter_first_buy" |
  //                       "kickstarter_invite_prospects" | etc.
  //   campaignSequence  = 1-5 for the WIN1..WIN5 progressive ladder under
  //                       the re-engage cohort. NULL for single-promo campaigns.
  //
  // Self-made promos have BOTH fields NULL.
  campaignRef      String?
  campaignSequence Int?

  // VIP group this promo was assigned to (Program 3). Set when the owner
  // assigns a promo to a whole CustomerGroup; lets the admin list badge it
  // "VIP: <group>". NULL for everything else. campaignRef is also stamped
  // "assigned_group:<id>" for symmetry with the 1:1 "assigned_manual".
  customerGroupId String?

  // ── Restrictions (embedded wizard knobs, NOT a separate modal) ───────
  //
  // Per Luigi's 2026-05-29 clarification: the 8 GloriaFood "restrictions"
  // (Happy Hour, Delivery Area, Cart Value, Payment, Expiration, Client
  // Type, Frequency, Exclusivity) are NOT a polymorphic JSON blob — they
  // are individual fields embedded across the promo creation wizard.
  // Most map to existing columns:
  //   Happy Hour    → daysOfWeek + usableHourStart/End
  //   Cart Value    → minimumOrder
  //   Expiration    → startsAt + endsAt
  //   Client Type   → customerType ("any" | "new" | "returning" | "member")
  //   Frequency     → usageLimit + onceLifetimePerClient + once-per-order-via-engine
  //   Exclusivity   → stackingRule ("standard" | "exclusive" | "master")
  // The two restrictions that need new dedicated columns:
  //   Delivery Area → deliveryZoneIds (JSON array of zone IDs; null = all)
  //   Payment       → paymentMethodSlugs (JSON array; null = all)
  paymentMethodSlugs       String? // JSON array; null = all enabled payment methods allowed
  deliveryZoneIds          String? // JSON array of DeliveryZone IDs; null = all zones
  onceLifetimePerClient    Boolean @default(false) // Frequency: once-per-client-forever
  // Limited showtime is a Display Time sub-mode (separate from Happy Hour
  // usableHour above): the promo is only VISIBLE at scheduled times.
  // Stored as JSON array: [{ dayOfWeek: 0-6, hourStart: 0-1440, hourEnd: 0-1440 }, ...]
  limitedShowtimeSchedules Json    @default("[]")

  // ── Display ──────────────────────────────────────────────────────────
  imageUrl           String?
  // menu_visible       → promo card shows alongside menu items (default)
  // hidden_coupon_only → promo only activates when the customer types the
  //                      coupon code (never shown in the menu)
  // popup              → modal pops up when the customer lands on /order/[slug]
  displayMode        String  @default("menu_visible")
  // When set: customer-facing "Add $X more to unlock!" tooltip on cart
  // when cart subtotal is within ($highlightThreshold) of the eligibility
  // minimum. Null = no nudge.
  highlightThreshold Float?

  // ── Type-specific config (all 13 promo types reuse this) ─────────────
  //
  // ruleConfig is the type-specific config for the 13 promotion types
  // (meal bundle slots, combo deal pairings, payment method slug,
  // freebie pick, buy-N positions, free-dish slot, etc). Shape is
  // dictated by promotionType. Empty {} for the simple % off types.
  // See src/lib/promo-engine.ts for the per-type shape contract.
  ruleConfig Json @default("{}")

  // ── Entitlement gate ─────────────────────────────────────────────────
  //
  // For promo types 6-13 (locked behind Advanced Promo Marketing add-on
  // @ $19.99/mo). NULL means free-tier type (no entitlement needed).
  // Set on POST; server checks restaurant.hasFeature(slug) on every
  // create/update so an owner can't bypass the paywall via direct API.
  requiredAddOnSlug String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant      Restaurant               @relation(fields: [restaurantId], references: [id])
  customerCoupons CustomerCoupon[]
  customerGroup   CustomerGroup?           @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)
  groupLinks      CustomerGroupPromotion[]
  vipSchedules    VipSchedule[]

  @@index([restaurantId, isActive])
  @@index([campaignRef])
  @@index([customerGroupId])
}

/// ── Coupon-grant ledger (Luigi 2026-06-09) ──────────────────────────────
/// Tracks, per customer (matched by email OR phone), which campaign coupons
/// they HOLD and whether each has TRULY been used. Redemption is tied to
/// ORDER FULFILLMENT, never to placement: a coupon applied to an order is
/// only "redeemed" once that order COMPLETES, and is "released" (made
/// available again) if the order is missed / rejected / cancelled / refunded.
/// So a coupon is never burned by an order that didn't happen — anywhere in
/// the system. This is the shared engine under Kickstarter (auto-apply
/// first-buy), Autopilot (per-campaign auto-apply OR code/link), and future
/// flyer/QR grants.
///
///   granted ──apply──▶ applied ──order completes──▶ redeemed
///                ▲          │
///                └──────────┘  order failed → released → available again
///
/// Deliberately a SIDE TABLE (sparse, off the hot Order/MenuItem tables) per
/// the scaling rules. `appliedOrderId` is a loose reference (not an FK) to
/// avoid a back-relation on the hot Order table.
model CustomerCoupon {
  id           String  @id @default(cuid())
  restaurantId String
  promotionId  String
  /// Denormalised from the promotion at grant time so "does this customer
  /// already hold a <campaign> coupon?" needs no join.
  campaignRef  String?

  /// WHO holds it — matched on EITHER identifier at checkout. At least one is
  /// set; customerId is filled in when the Customer row is resolvable.
  email      String?
  phone      String?
  customerId String?

  /// Code shown / typed (mirrors the promotion's couponCode).
  code      String?
  /// Snapshot of the owning campaign's auto-apply setting AT GRANT TIME, so a
  /// later config change can't retroactively change how this grant behaves.
  autoApply Boolean @default(false)

  /// granted | applied | redeemed | released | expired | revoked
  status      String  @default("granted")
  /// What created this grant: "rule:new_customer", "kickstarter_first_buy",
  /// "autopilot_reengage_win3", "invite", "flyer:<code>", ...
  grantSource String?

  grantedAt      DateTime  @default(now())
  /// The order it is CURRENTLY applied to (while status = applied); retained
  /// as the redeeming order once redeemed; cleared on release.
  appliedOrderId String?
  appliedAt      DateTime?
  redeemedAt     DateTime?
  releasedAt     DateTime?
  /// Optional hard validity window (e.g. first-buy good for 90 days).
  expiresAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  promotion  Promotion  @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Checkout lookups: "active grants for this identity at this restaurant".
  @@index([restaurantId, email, status])
  @@index([restaurantId, phone, status])
  @@index([restaurantId, promotionId, status])
  @@index([appliedOrderId])
  // Code-redemption lookup (resolveAssignedPromoByCode): "is there a grant with
  // this code at this restaurant?" before matching the checkout identity.
  @@index([restaurantId, code])
}

// ─── VIP Customer Groups (Program 3, 2026-06-27) ───────────────────────
//
// Named groups of customers (e.g. "Milton Soccer") the owner can assign a
// promotion to ALL AT ONCE. A group mixes registered restaurant-customers
// (linked by customerId) AND guests / not-yet-customers (raw email/phone) —
// same identity model as CustomerCoupon, so assigning a group promo just loops
// grantCoupon() over the members. Restaurant-customer accounts only (the
// marketplace CustomerAccount is separate). Free feature.
model CustomerGroup {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  /// Per-group "what do you call your members" override (e.g. "Bruce Trail Staff"
  /// vs "VIP Pizza Club"). Null → the restaurant-level Restaurant.vipMemberLabel
  /// default. Used in the VIP email/special copy for this group. Luigi 2026-06-30.
  memberLabel  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant      Restaurant               @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  members         CustomerGroupMember[]
  promotions      Promotion[]
  // Member-only specials attached to this group (Phase 1 of the VIP expansion):
  // a promotion linked here becomes member-only — hidden from the public menu and
  // auto-applied only for this group's members. Replaces the old inline-create.
  groupPromotions CustomerGroupPromotion[]
  vipSchedules    VipSchedule[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

// Links a promotion to a VIP TARGET — either a whole group OR a specific
// individual (an account by customerId, and/or a person by email/phone). The
// presence of ANY link makes a promotion "member-only" (excluded from the public
// pool/banner, auto-applied only for the matching members/individuals). A
// promotion can have many targets; a group can hold several specials. Per-link
// scheduling fields (recurring auto-send) get added in a later phase.
model CustomerGroupPromotion {
  id           String   @id @default(cuid())
  promotionId  String
  restaurantId String // denormalised for scoping without a join
  // Target = exactly one shape: a group, OR an individual (customerId and/or
  // email/phone). For an individual we store the email (lowercased) AND the
  // customerId when it resolves to an account, so checkout matches a signed-in
  // member by id and a guest by typed email.
  groupId      String?
  customerId   String?
  email        String?
  phone        String?
  createdAt    DateTime @default(now())

  group     CustomerGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  customer  Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  promotion Promotion      @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([groupId, promotionId])
  @@index([groupId])
  @@index([promotionId])
  @@index([restaurantId])
  @@index([restaurantId, email])
  @@index([restaurantId, customerId])
}

model CustomerGroupMember {
  id           String @id @default(cuid())
  groupId      String
  // Denormalised so member queries / scoping never need to join the group.
  restaurantId String

  // A member is EITHER a linked restaurant-customer (customerId set) OR a raw
  // contact typed/pasted by the owner (email/phone/name) for someone who hasn't
  // ordered yet. At least one identifier is set; customerId is filled in when a
  // matching Customer row exists (or is later created).
  customerId String?
  email      String?
  phone      String?
  name       String?

  addedAt DateTime @default(now())

  group    CustomerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  customer Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // A linked customer can only be in a group once.
  @@unique([groupId, customerId])
  @@index([groupId])
  // Checkout resolves "which groups is this identity in?" by customerId/email/phone
  // (restaurant-scoped). All three are indexed so Postgres can bitmap-OR them on
  // the hot order path. Luigi 2026-06-27.
  @@index([restaurantId, email])
  @@index([restaurantId, phone])
  @@index([restaurantId, customerId])
}

// ─── VIP recurring scheduler (Program 2, 2026-06-27) ───────────────────
// Drives recurring/scheduled auto-sends: drop Reward Dollars credit on a cadence
// ("credit_grant"), or re-send an existing member-only discount special
// ("discount_resend"). Kept SEPARATE from CustomerGroupPromotion (which is read
// on the checkout hot path) so scheduling never bloats that table. A pure lib
// (src/lib/vip-schedules.ts) computes nextRunAt; a 5-min cron fires due rows.
// VipScheduleGrant is the hard idempotency guard (≤1 grant per recipient per
// period). Recipients are resolved LIVE at fire time so members added later are
// included.
model VipSchedule {
  id           String @id @default(cuid())
  restaurantId String
  kind         String // "credit_grant" | "discount_resend"

  // discount_resend: which member-only promotion to re-announce.
  promotionId String?
  // credit_grant: how much credit + an optional ledger note.
  amount      Float?
  note        String?

  // Target = a group OR an individual (customerId and/or email). Mirrors the VIP
  // target model; recipients are resolved live when the schedule fires.
  groupId    String?
  customerId String?
  email      String?

  // Cadence + when within it. dayOfWeek 0–6 (weekly), dayOfMonth 1–31 (monthly,
  // clamped to the month length). sendHour "HH:mm" in the restaurant's timezone.
  cadence    String // "once" | "daily" | "weekly" | "monthly"
  dayOfWeek  Int?
  dayOfMonth Int?
  sendHour   String @default("09:00")
  startDate  String // "YYYY-MM-DD" in the restaurant's timezone

  active           Boolean   @default(true)
  nextRunAt        DateTime?
  lastRunAt        DateTime?
  // tz date-key (YYYY-MM-DD) of the last fire — guards against double-firing
  // within one local day if the cron runs twice.
  lastFiredDateKey String?
  runCount         Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  group      CustomerGroup?     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  promotion  Promotion?         @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  customer   Customer?          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  grants     VipScheduleGrant[]

  @@index([active, nextRunAt])
  @@index([restaurantId])
}

// One row per (schedule, period, recipient) — the double-grant guard. periodKey
// is the tz-local period bucket (e.g. "2026-06" monthly, "2026-W26" weekly,
// "2026-06-27" daily, "once"); recipientKey is `customerId` or `"email:"+email`.
model VipScheduleGrant {
  id           String   @id @default(cuid())
  scheduleId   String
  periodKey    String
  recipientKey String
  customerId   String?
  email        String?
  rewardId     String? // RewardLedger id for a credit_grant (audit trail)
  amount       Float    @default(0)
  createdAt    DateTime @default(now())

  schedule VipSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, periodKey, recipientKey])
  @@index([scheduleId])
}

// ─── Reward Dollars wallet (store credit, Program 3, 2026-06-27) ────────
// Per-restaurant store credit a customer spends as PARTIAL PAYMENT at checkout.
// Mirrors the coupon-ledger philosophy: an append-only ledger is the source of
// truth, the cached balance is mutated atomically, and money is consumed/earned
// on FULFILLMENT (completed order), released on miss/reject. One canonical
// balance row per (restaurant, customer) so the atomic decrement is safe.
model RewardAccount {
  id               String   @id @default(cuid())
  restaurantId     String
  customerId       String
  balance          Float    @default(0)
  lifetimeEarned   Float    @default(0)
  lifetimeRedeemed Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurant Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customer   Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  ledger     RewardLedger[]

  @@unique([restaurantId, customerId]) // one wallet per customer per restaurant
  @@index([restaurantId])
}

// Append-only ledger. amount is SIGNED (+earn/grant/release, −spend); reason is
// one of earn|grant|signup_bonus|spend|release|adjust|expire. The
// @@unique([accountId, orderId, reason]) caps it at ≤1 spend AND ≤1 earn per
// order per account — the idempotency backbone for the completion/cron hooks.
model RewardLedger {
  id           String   @id @default(cuid())
  accountId    String
  amount       Float
  balanceAfter Float
  reason       String
  status       String? // for spend rows: "applied" → "redeemed" | "released"
  orderId      String?
  note         String?
  createdAt    DateTime @default(now())

  account RewardAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, orderId, reason])
  @@index([accountId, createdAt])
  @@index([orderId])
}

// ─── Configurable earning rules / campaigns (Reward Dollars, 2026-06-27) ──
// Each restaurant defines MANY ways customers earn credit, on top of the base
// %-back set on Restaurant.rewardEarn*. Side table (sparse, off the hot tables).
// Triggers: signup (optionally date-windowed campaign), first_order, order_over
// (subtotal ≥ threshold), nth_order (every Nth completed order). Amount is a flat
// earnAmount OR earnPercent of the order basis. startsAt/endsAt are absolute
// instants (the admin API converts picked dates to the restaurant's tz day
// bounds), so rule evaluation stays pure/timezone-free. Each fired grant is
// idempotent via the ledger reason `earn:<trigger>:<ruleId>`.
model RewardEarnRule {
  id             String    @id @default(cuid())
  restaurantId   String
  active         Boolean   @default(true)
  triggerType    String // "signup" | "first_order" | "order_over" | "nth_order"
  earnAmount     Float? // flat credit granted
  earnPercent    Float? // OR % of the order basis (order triggers)
  orderThreshold Float? // order_over: minimum order subtotal to qualify
  nthInterval    Int? // nth_order: every Nth completed order (e.g. 5)
  startsAt       DateTime? // campaign window (absolute instants); null = always
  endsAt         DateTime?
  label          String?
  /** Advertise this earn rule as a customer-facing tile in the order page's
   *  Promos section ("Earn $5 on your first order"). Luigi 2026-06-28. */
  showInPromos   Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, active])
}

// ─── Marketing Suite (GloriaFood parity, 2026-05-29) ───────────────────
//
// Three pillars under /admin/marketing-tools, each with its own state row
// per restaurant: Kickstarter (acquire), Autopilot (retain), and the
// Promotions catalog. Pre-made promos auto-generated by Kickstarter and
// Autopilot live as Promotion rows with campaignRef set; they cascade
// active/inactive with their owning campaign's toggle.

/// Per-restaurant Autopilot state. ONE row per restaurant — upserted on
/// first /admin/autopilot visit.
///
/// `masterEnabled` is the GloriaFood "Activate Autopilot Selling? Yes/No"
/// gate at the top of the page. When OFF, no campaign sends regardless of
/// the individual toggles. When ON, each campaign-specific boolean below
/// gates whether THAT campaign fires.
///
/// Last-run timestamps are CRON dedup — prevent the hourly cron from
/// re-processing the same restaurant within a campaign-specific window
/// (re-engage runs at most once per day, cart-abandonment can run every
/// hour, second-order daily).
model AutopilotState {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  // Master gate
  masterEnabled Boolean @default(false)

  // Individual campaign toggles
  secondOrderEnabled     Boolean @default(false)
  reEngageEnabled        Boolean @default(false)
  cartAbandonmentEnabled Boolean @default(false)

  // Cron dedup
  lastSecondOrderRun DateTime?
  lastReEngageRun    DateTime?
  lastCartAbandonRun DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Per-restaurant Kickstarter state. ONE row per restaurant — upserted
/// on first /admin/kickstarter visit. No master gate at the Kickstarter
/// level (the 2 products toggle independently).
model KickstarterState {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  firstBuyPromoEnabled   Boolean @default(false)
  inviteProspectsEnabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Customer cart session. Created on first cart-touch (heartbeat from
/// /order/[slug] when the customer adds an item). Updated as the cart
/// changes. Becomes "abandoned" when no activity for 1-2 hours (config
/// per restaurant via Autopilot settings). Cart-abandonment cron then
/// fires the recovery email + suppresses if `recoveredAt` set (any
/// order from same email within window — Luigi-confirmed).
///
/// Anonymous sessions (sessionToken-only, no email/phone) are tracked but
/// CAN'T be emailed. Once the customer reaches the checkout form, we
/// capture email and the session becomes addressable.
model CartSession {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  /// Anonymous browser identifier (set in localStorage on first visit).
  /// Unique across the platform so we can dedup if the same user opens
  /// multiple tabs.
  sessionToken String @unique

  /// Customer identity — null until checkout form filled.
  customerEmail String?
  customerPhone String?
  customerId    String? // FK to Customer if matched on save

  /// Cart state — snapshot for personalizing the recovery email
  /// ("come back for your Margherita Pizza!"). cartJson is denormalized
  /// since menu items can change after the abandonment.
  itemCount Int   @default(0)
  cartTotal Float @default(0)
  cartJson  Json  @default("[]")

  /// Lifecycle
  lastTouchedAt   DateTime  @default(now()) @updatedAt
  reachedCheckout Boolean   @default(false) // entered email/phone
  abandonedAt     DateTime? // set by sweep when stale
  recoveredAt     DateTime? // set when order found
  emailSentAt     DateTime? // recovery email dispatched

  createdAt DateTime @default(now())

  // Cart-abandonment cron filter — find recently-abandoned, not-yet-
  // recovered, not-yet-emailed sessions.
  @@index([restaurantId, abandonedAt])
  // Suppression lookup — "any order from this email since abandonment?"
  @@index([customerEmail])
}

/// CSV import batch for Kickstarter → Invite Prospects. One per upload.
/// Holds aggregate stats + lifecycle so the owner can see "47 of 100
/// emails sent, 2 bounced, 1 unsubscribed."
model ProspectImport {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  filename    String
  totalRows   Int
  successRows Int    @default(0) // parsed + persisted
  errorRows   Int    @default(0) // invalid email / dup / etc.

  /// Send state — set as the throttled send batch progresses.
  emailsSent     Int       @default(0)
  emailsLastSent DateTime?
  isComplete     Boolean   @default(false)

  uploadedAt DateTime   @default(now())
  prospects  Prospect[]

  @@index([restaurantId, uploadedAt])
}

/// Individual prospect from a CSV import. Each is a candidate to receive
/// one invite email with a pre-made Kickstarter coupon code.
model Prospect {
  id       String         @id @default(cuid())
  importId String
  import   ProspectImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  name  String?
  email String
  phone String?

  /// Email lifecycle — null fields mean "hasn't happened yet."
  emailSentAt    DateTime?
  emailBouncedAt DateTime?
  unsubscribedAt DateTime?

  /// Conversion tracking — set if this prospect later created a Customer
  /// row (e.g. signed up + ordered). Lets the owner see ROI of the
  /// invite campaign.
  convertedToCustomerId String?

  createdAt DateTime @default(now())

  @@index([importId])
  @@index([email])
}

model DeliveryZone {
  id               String   @id @default(cuid())
  restaurantId     String
  name             String
  color            String   @default("#f97316")
  centerLat        Float    @default(0)
  centerLng        Float    @default(0)
  radiusKm         Float    @default(5)
  deliveryFee      Float    @default(0)
  minimumOrder     Float    @default(0)
  estimatedMinutes Int      @default(30)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]

  @@index([restaurantId])
}

model OpeningHours {
  id            String  @id @default(cuid())
  restaurantId  String
  dayOfWeek     Int
  isOpen        Boolean @default(true)
  openTime      String  @default("09:00")
  closeTime     String  @default("21:00")
  // When true, closeTime is interpreted as belonging to the NEXT
  // calendar day (e.g. Fri row with openTime=17:00, closeTime=02:00,
  // closesNextDay=true means "open Friday 5pm through Saturday 2am").
  // The customer-side openness check uses this to keep showing "Open"
  // through midnight rather than flipping to "Closed" at 23:59. Added
  // 2026-05-24 after UAT — Luigi noted bars/late-night spots couldn't
  // express their real hours without this.
  closesNextDay Boolean @default(false)
  /// Service this row applies to. null = the legacy "all services"
  /// row (regular opening hours, used for ANY service that doesn't
  /// have a more specific row). Specific values: "pickup" / "delivery"
  /// / "reservation". GloriaFood-parity: lets a restaurant be open for
  /// reservations 11–14 + 19–22 but only accept delivery 19–22. Lookup
  /// pattern: prefer the row matching the active service, fall back to
  /// the null/default row when no override exists. Added 2026-05-31.
  service       String?
  /// Split hours (2026-06-24): JSON array of open intervals for this
  /// day/service — [{ "open":"12:00","close":"15:00" },
  /// { "open":"18:00","close":"23:00","closesNextDay":false }]. When present
  /// AND non-empty it REPLACES openTime/closeTime; those are kept dual-written
  /// as a back-compat "envelope" (earliest open / latest close) so any legacy
  /// reader still works. Null / [] = legacy single window (read openTime/
  /// closeTime). Mirrors RestaurantHoliday.rules. Read via rowIntervals() in
  /// src/lib/restaurant-hours.ts — never the raw column.
  intervals     Json?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, dayOfWeek, service])
}

// One-off holiday closures (Christmas Day, July 4th, owner vacation,
// etc.). When today's date matches a row here, the restaurant is
// considered closed regardless of the weekly OpeningHours schedule.
// Date stored as @db.Date so timezone shifts don't smear a holiday
// across two adjacent calendar days.
model RestaurantHoliday {
  id           String    @id @default(cuid())
  restaurantId String
  date         DateTime  @db.Date
  // Optional human label ("Christmas Day", "Owner vacation"). Shown to
  // customers on the hosted site / order page when the restaurant is
  // closed for this reason. Falls back to a generic "Closed today" if
  // empty.
  name         String?
  /// Gloriafood-parity special days (Luigi 2026-06-11, reseller report
  /// cmpxds2d2). All three additive + nullable so every pre-existing row
  /// keeps its legacy meaning: "fully closed, all services, single day".
  ///
  /// endDate — makes the entry a PERIOD (date..endDate inclusive, calendar
  /// dates). Null = single day.
  endDate      DateTime? @db.Date
  /// JSON array of per-service rules:
  ///   [{ "services": null | ["pickup","delivery","dine_in","take_out",
  ///      "catering","reservation"],          // null/empty = ALL services
  ///      "mode": "closed" | "open",          // open = custom hours that day
  ///      "intervals": [{"open":"10:00","close":"20:00"}, …] }]   // mode=open
  /// Null = legacy: closed, all services. Resolution: a rule naming the
  /// specific service beats an all-services rule; "closed" beats "open".
  /// Parsed/enforced by src/lib/holiday-rules.ts.
  rules        String?
  /// Optional customer-facing notification (max 200 chars) shown in the
  /// closed/special-hours banner on the ordering page.
  message      String?
  createdAt    DateTime  @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, date])
  @@index([restaurantId, date])
}

model ReceiptTemplate {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  type         String   @default("customer")
  template     String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

model PrinterSettings {
  id                   String   @id @default(cuid())
  restaurantId         String   @unique
  // PrintNode credentials (AES-256-GCM encrypted)
  printNodeApiKeyEnc   String?
  printNodeApiKeyIv    String?
  printNodeApiKeyTag   String?
  printNodeConnected   Boolean  @default(false)
  printNodeAccountName String?
  selectedPrinterId    Int? // PrintNode printer ID
  selectedPrinterName  String? // Cached printer display name
  // Print options
  autoPrint            Boolean  @default(false)
  printKitchen         Boolean  @default(true)
  printCustomer        Boolean  @default(true)
  kitchenCopies        Int      @default(1)
  customerCopies       Int      @default(1)
  paperWidth           String   @default("80mm")
  fontSize             String   @default("normal")
  showLargeOrderNumber Boolean  @default(true)
  showLogo             Boolean  @default(false)
  printerLanguage      String   @default("escpos") // escpos | starprnt | plaintext
  createdAt            DateTime @default(now())
