// ─── Reseller Partner Program ──────────────────────────────────────────────
//
// One ResellerProfile per reseller_partner user. Status drives whether they
// can log in / earn commission. The referralCode is appended to signup URLs
// (/signup?ref=<code>) so attribution is set at restaurant creation time —
// see src/app/api/auth/register/route.ts.
model ResellerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Application + approval lifecycle
  status           String    @default("pending") // pending | approved | suspended | rejected
  companyName      String?
  website          String?
  country          String?
  applicationNotes String? // what they wrote on the application form
  approvedAt       DateTime?
  approvedBy       String? // superadmin User.id
  suspendedAt      DateTime?
  suspendedReason  String?

  // Payout preferences. Money is sent manually by the superadmin per the
  // chosen method; payoutDetails is an encrypted JSON blob (PayPal email,
  // bank routing info, etc.) using the same AES-GCM envelope as Stripe keys.
  payoutMethod     String?
  payoutDetails    String?
  payoutDetailsIv  String?
  payoutDetailsTag String?

  referralCode     String @unique @default(cuid())
  totalEarnedCents Int    @default(0) // lifetime gross
  totalPaidCents   Int    @default(0) // lifetime payouts marked paid

  // Superadmin can pin a custom flat rate that overrides the default tier
  // table (0/5/10%). When non-null, recordCommissionForInvoice uses this
  // value regardless of active-paying count. Useful for VIP partners.
  customCommissionRate Float? // percent, e.g. 7 means 7%

  /// White-label / branding fields. When populated and the reseller has
  /// an active white-label add-on subscription (status check + currentPeriodEnd
  /// in the future), these values flow into the imprint footer of
  /// receipts + transactional emails for every restaurant attributed
  /// to this reseller. Free for the moment — Stripe paywall is Phase 2.
  /// Receipts: receipt-lines builder reads imprint via setEmailImprint().
  /// Phase 1 ships with imprint+logoUrl persistence; Phase 2 wires the
  /// paid add-on subscription + custom domain handling.
  imprint         String? // e.g. "Supported by Partner LLC | contact@partner.com | +1 234"
  brandLogoUrl    String? // optional uploaded logo (S3 URL)
  brandLoginTitle String? // custom title shown on the reseller-branded login page (Phase 2)

  /// Brand colors for the reseller-branded LOGIN + SIGNUP pages (and any future
  /// reseller-skinned surface). Hex strings like "#10b981". When set AND white-label
  /// is active, they replace the platform emerald on the branded auth pages; null
  /// falls back to the platform default. Sparse + low-cardinality (one row per
  /// reseller) so nullable columns here are cheap. Luigi 2026-06-23.
  brandPrimaryColor String? // primary brand color — buttons, links, accents
  brandAccentColor  String? // optional secondary / accent color
  /// Reseller's custom LOGIN/SIGNUP background image (Vercel Blob URL). When set + white-label
  /// active, replaces the default FeeFree food-hero background on their branded auth pages.
  /// Luigi 2026-06-23.
  brandLoginBgUrl   String?

  /// When this reseller is de-branded (approved + imprint/logo) the platform
  /// "Powered by Fee Free Ordering" credit is hidden on their restaurants' customer
  /// pages. This flag controls what shows IN ITS PLACE: true (default) shows
  /// "Powered by {companyName}" (the reseller's own credit -> consistent branding);
  /// false shows nothing (a fully clean storefront). Direct (non-reseller) restaurants
  /// always show the Fee Free credit regardless. Luigi 2026-06-24.
  showCustomerPageCredit Boolean @default(true)

  /// Stripe Customer for this reseller. Created lazily the first time
  /// the reseller starts a white-label Checkout. Reused across renewals
  /// + future add-on subscriptions so the reseller has one cohesive
  /// billing identity in Stripe.
  stripeCustomerId String? @unique

  /// White-label subscription state. Post-restructure (Luigi 2026-06-23) there is ONE paid tier:
  ///   "full"  — "Branded" $19.99/mo: branded login page + custom domain.
  ///   "basic" — LEGACY only (the retired $9.99 email-only tier); no new subscription uses it.
  /// FREE de-brand (imprint + logo on emails, no subscription) is gated separately on an approved
  /// reseller who configured branding — see isResellerDebranded() in src/lib/white-label.ts.
  /// Set when the reseller completes Stripe Checkout; reset to null on cancel/expire.
  whiteLabelTier                 String? // "basic" | "full" | null
  whiteLabelStatus               String? // "active" | "past_due" | "cancelled" | null
  whiteLabelStripeSubscriptionId String?   @unique
  whiteLabelCurrentPeriodEnd     DateTime?
  whiteLabelCancelAtPeriodEnd    Boolean   @default(false)

  /// Custom domain for the reseller's white-label landing + login.
  /// Only meaningful on the paid "Branded" tier (whiteLabelTier === "full"),
  /// which includes custom-domain branding. Parallel to Restaurant's
  /// customDomain fields but scoped to the reseller, so a partner can use
  /// their own apex like `mypartner.com` for the login screen / future
  /// reseller marketing landing while their restaurants stay on their own
  /// subdomains / domains as configured separately.
  ///
  /// Lifecycle states (customDomainStatus):
  ///   "none"      — no domain configured (default)
  ///   "pending"   — domain registered with our domain provider (Vercel),
  ///                 awaiting customer to update DNS at their registrar
  ///   "verifying" — DNS present, SSL / propagation still in progress
  ///   "verified"  — fully live + SSL provisioned; proxy routes the host
  ///   "error"     — provider reported a problem; details in
  ///                 customDomainError. Caller may retry verify.
  customDomain        String?   @unique
  customDomainStatus  String    @default("none")
  customDomainAddedAt DateTime?
  customDomainError   String?

  /// Generic platform subdomain (e.g. "acme" → acme.feefreeordering.com).
  /// Free with any white-label tier (Basic OR Full). No DNS needed —
  /// we run a wildcard cert on the platform domain. Validated against
  /// the same RESERVED_SUBDOMAINS list restaurants use (so resellers
  /// can't claim "www" / "app" / etc.). Unique across both ResellerProfile
  /// and Restaurant.subdomain (enforced application-side at write time —
  /// Prisma can't @@unique across two tables, but the proxy resolves
  /// restaurants FIRST then falls back to resellers, so a collision
  /// silently routes to the restaurant).
  genericSubdomain String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurants Restaurant[]
  commissions CommissionTransaction[]
  payouts     PayoutRequest[]

  @@index([status])
  @@index([referralCode])
  // Proxy lookup: "is this hostname a reseller's verified custom domain?"
  // Filtered to verified so unverified domains don't leak access.
  @@index([customDomainStatus])
  // Reseller dashboard + admin pages frequently filter by whiteLabelStatus
  // to find active subscribers vs lapsed ones. Added 2026-05-28 during
  // the pre-launch scale sweep — the `status` index already covers the
  // "approved vs pending" filter, this covers the white-label tier
  // queries.
  @@index([whiteLabelStatus])
}

// Many-to-many between User and Restaurant for non-owner access. The owning
// restaurant_admin uses User.restaurantId; everything else (reseller managers,
// shared staff, future delegation) goes here. accessRole bounds what they can
// do at the route level.
model RestaurantAccess {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  accessRole   String // owner | reseller_manager | manager | staff | readonly
  grantedBy    String? // user id of who granted this access
  grantedAt    DateTime   @default(now())

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

// One row per SubscriptionInvoice that earns commission for a reseller.
// Idempotent by subscriptionInvoiceId unique. The snapshot fields
// (activePayingCount, ratePercent, netRevenueCents) are frozen at recording
// time so we can audit how each amount was derived.
model CommissionTransaction {
  id                    String              @id @default(cuid())
  resellerProfileId     String
  resellerProfile       ResellerProfile     @relation(fields: [resellerProfileId], references: [id], onDelete: Cascade)
  restaurantId          String
  restaurant            Restaurant          @relation(fields: [restaurantId], references: [id])
  subscriptionInvoiceId String              @unique
  subscriptionInvoice   SubscriptionInvoice @relation(fields: [subscriptionInvoiceId], references: [id])

  netRevenueCents   Int
  activePayingCount Int
  ratePercent       Float
  commissionCents   Int

  status          String         @default("pending") // pending | available | paid | reversed
  reversedAt      DateTime?
  reversedReason  String?
  payoutRequestId String?
  payoutRequest   PayoutRequest? @relation(fields: [payoutRequestId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resellerProfileId, status])
  @@index([restaurantId])
}

// A reseller's request to be paid out. Includes one or more commissions.
// Superadmin approves and then marks paid after sending money out-of-band.
model PayoutRequest {
  id                String          @id @default(cuid())
  resellerProfileId String
  resellerProfile   ResellerProfile @relation(fields: [resellerProfileId], references: [id], onDelete: Cascade)

  amountCents    Int
  currency       String    @default("usd")
  status         String    @default("requested") // requested | approved | paid | rejected | cancelled
  requestedAt    DateTime  @default(now())
  approvedAt     DateTime?
  approvedBy     String?
  paidAt         DateTime?
  paidBy         String?
  rejectedAt     DateTime?
  rejectedReason String?

  payoutReference String?
  notes           String?

  commissions CommissionTransaction[]

  @@index([resellerProfileId, status])
}

// ─── Phase 1: Add-on catalog + per-restaurant subscriptions ────────────────
//
// We're decoupling "plan" (free for everyone going forward) from "add-ons"
// (individual feature unlocks billed independently). The old SubscriptionPlan
// model stays as-is for backward compatibility; new signups land on a Free
// plan there. AddOn is a flat catalog of features owners can subscribe to,
// each with its own Stripe Price.

model AddOn {
  id                   String  @id @default(cuid())
  slug                 String  @unique
  name                 String
  description          String?
  monthlyPriceCents    Int     @default(0)
  yearlyPriceCents     Int?
  trialDays            Int?
  isActive             Boolean @default(true)
  /// When true, the add-on is visible in the catalog as a teaser but cannot
  /// be subscribed to. /admin/billing/add-ons renders a "Coming Soon" badge
  /// in place of the price + a disabled CTA explaining the feature is in
  /// development. Used for products we're advertising but haven't built yet
  /// (POS Module, Branded Mobile App, Phone Ordering, etc.) so prospective
  /// restaurants see the roadmap without us mis-selling vapor.
  comingSoon           Boolean @default(false)
  displayOrder         Int     @default(0)
  /// JSON-encoded array of feature slugs this add-on unlocks. e.g.
  /// `["card_payments","stripe_connect"]` for online_payments. Keeping this
  /// as a JSON string instead of a relation table keeps Phase 1 simple; we
  /// can split to a relation later if the list gets unwieldy.
  enabledFeatures      String  @default("[]")
  /// JSON-encoded array of other add-on slugs that must be active for this
  /// to work (e.g. custom_domain requires hosted_website).
  requiredDependencies String  @default("[]")
  /// GrowthNet bundle membership. When true, this add-on's enabledFeatures
  /// are ALSO granted to every restaurant with an active `growthnet`
  /// subscription (Fee Free's Restaurant Growth System — every paid
  /// marketing / retention / acquisition add-on at one discounted price).
  /// Membership is data-driven on purpose: flag a future add-on true and
  /// every GrowthNet subscriber gets it automatically, zero code changes.
  /// Luigi 2026-06-11.
  inGrowthNet          Boolean @default(false)
  /// Stripe wiring — populated when the superadmin syncs an add-on (Phase 5).
  stripePriceId        String? @unique
  stripeProductId      String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurantAddOns RestaurantAddOn[]

  @@index([slug])
}

model RestaurantAddOn {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  addOnId      String
  addOn        AddOn      @relation(fields: [addOnId], references: [id])

  status               String    @default("active") // active | trialing | past_due | cancelled | incomplete
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  trialEndsAt          DateTime?
  /// Failed-payment grace deadline (Luigi 2026-06-15). When this add-on's
  /// charge fails we set status=past_due AND graceEndsAt=now+10d; the
  /// entitlement check (src/lib/entitlements.ts) keeps GRANTING this add-on's
  /// features while past_due AND graceEndsAt > now, so service doesn't cut on
  /// day 1. Once graceEndsAt passes the feature drops automatically. Mirrors
  /// the restaurant-level Restaurant.graceEndsAt clock; denormalized here so
  /// the hot-path entitlement query stays a single flat table read (no join).
  graceEndsAt          DateTime?
  activatedAt          DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, addOnId])
  @@index([restaurantId])
  @@index([status])
}

/// Marketplace Listing — per-restaurant settings for the public
/// Fee Free Ordering Marketplace at /marketplace. A row is created
/// automatically the moment the restaurant's "marketplace" add-on
/// subscription activates (see src/lib/stripe/events/subscription.ts).
///
/// The presence of the row + isListed=true + an active
/// `marketplace_listing` entitlement on the restaurant is what
/// determines whether it appears in the public grid. Toggling
/// isListed off lets a restaurant temporarily pause discovery
/// (e.g. while they fix a menu issue) without canceling the
/// subscription.
model MarketplaceListing {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  /// User-controllable "pause" toggle. Distinct from the entitlement
  /// (which is controlled by subscription status). When false, the
  /// restaurant is hidden from /marketplace but still pays for the
  /// add-on — they're just temporarily not accepting new customers
  /// from the marketplace channel.
  isListed Boolean @default(true)

  /// Marketplace billing mode the restaurant chose:
  ///   "payg"    — pay-as-you-go: $3 per marketplace order, capped at
  ///               $249.99/month. NO Stripe subscription; the monthly
  ///               settlement cron creates a one-off invoice each cycle.
  ///               Driver Pool is NOT bundled — restaurant needs the
  ///               standalone Driver Pool add-on if they want it.
  ///   "monthly" — flat $199.99/month via Stripe subscription (the
  ///               `marketplace` AddOn). Driver Pool bundled free.
  ///               Set by the subscription webhook on activation.
  /// Defaults to "payg" because that's the friction-free opt-in path —
  /// no card required to start, no surprises until they actually drive
  /// orders through the marketplace.
  billingMode String @default("payg")

  /// True when the restaurant has explicitly clicked "Switch to PAYG"
  /// on /admin/marketplace/payg-opt-in (or the billing page). We set
  /// Stripe's `cancel_at_period_end = true` on their Monthly subscription
  /// so they keep Monthly benefits until the current cycle ends, then
  /// the subscription.deleted webhook reads this flag to decide what to
  /// do at cancellation:
  ///   - flag TRUE  → preserve listing (isListed stays true), flip
  ///                  billingMode to "payg", reset this flag. PAYG
  ///                  billing kicks in seamlessly.
  ///   - flag FALSE → existing behavior — hide listing (isListed=false),
  ///                  reset billingMode="payg" as the safe default. The
  ///                  restaurant has to re-opt-in manually.
  /// Cleared whenever the listing comes back online or the user undoes
  /// the switch (by clicking "Stay on Monthly").
  switchToPaygOnCancel Boolean @default(false)

  /// JSON string array — categories the customer can filter by on
  /// the marketplace browse page. e.g. ["pizza", "italian", "delivery"].
  /// Defaulted from restaurant.cuisineType at creation time but
  /// fully overridable.
  marketplaceCategories String @default("[]")

  /// JSON string array — short visual tags shown on the tile.
  /// e.g. ["family-friendly", "late-night", "vegetarian-options"].
  marketplaceTags String @default("[]")

  /// Banner image for the marketplace tile. Defaults to restaurant.bannerUrl
  /// at creation time, but admins can upload a different one tuned for
  /// the marketplace context (e.g. a wider crop showing more food).
  marketplaceBanner String?

  /// One-line hook shown on the marketplace tile. Falls back to
  /// restaurant.slogan, then restaurant.description first sentence.
  marketplaceTagline String?

  /// 1-2 sentence description shown on the restaurant detail page in
  /// the marketplace context. Falls back to restaurant.description.
  marketplaceShortDesc String?

  /// Superadmin-only flag — promotes the restaurant to the top of the
  /// browse grid + a "Featured" badge. Used for paid promotion within
  /// the marketplace (a future revenue stream) or to spotlight new
  /// restaurants during their first month.
  marketplaceFeatured Boolean @default(false)

  /// Manual ordering — when null, sort alphabetically. Admins can
  /// drag-and-drop to reorder; superadmins can pin specific
  /// restaurants to the top of the chain-wide grid.
  marketplaceSortOrder Int @default(0)

  /// Smart-billing counters (M2 will use these). On every order placed
  /// through the marketplace channel, increment these so we can show
  /// "this month so far: 42 orders / $1,247 in revenue / paid $X via
  /// marketplace, would have paid $Y on UberEats".
  currentMonthOrders    Int      @default(0)
  currentMonthRevenue   Float    @default(0)
  /// When the current billing month started (rolled forward by the
  /// monthly billing cron). Used to know when to reset the counters.
  currentMonthStartedAt DateTime @default(now())

  /// Cumulative savings vs UberEats's 30% commission, in cents.
  /// Computed as: sum over all marketplace orders of (order_total * 0.30)
  /// minus the marketplace subscription cost. Displayed prominently on
  /// the admin dashboard as the headline "value delivered" number.
  lifetimeSavingsVsUberEatsCents Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isListed])
  @@index([marketplaceFeatured])
}

/// ShipDay third-party driver pool configuration — per-restaurant.
/// Created when the restaurant first opts in to the driver_pool
/// feature (via either the standalone "driver_pool" add-on or the
/// bundled access from the "marketplace" add-on).
///
/// Stores the restaurant's ShipDay API credentials (encrypted at rest)
/// + their per-delivery fee strategy. The kitchen display reads this
/// row to decide whether the "send to driver pool" picker is enabled
/// for each order.
model ShipdayConfig {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  /// Master enable. Off by default even after the add-on activates —
  /// the restaurant has to enter their ShipDay credentials AND flip
  /// this before any orders route to the pool. Prevents accidentally
  /// dispatching to a misconfigured ShipDay account.
  enabled Boolean @default(false)

  /// ShipDay API key, encrypted with the platform's ENCRYPTION_KEY
  /// (same scheme as PlatformSettings.stripeSecretKey). Null until
  /// the restaurant pastes their key in /admin/delivery/pool.
  apiKeyEnc String?
  apiKeyIv  String?
  apiKeyTag String?

  /// How the per-delivery fee flows:
  ///   "pass_through" — customer pays the entire ShipDay fee (most common)
  ///   "flat"         — customer pays `flatDeliveryFee`, restaurant absorbs
  ///                    the difference if ShipDay charges more
  ///   "tiered"       — `tieredRules` JSON defines fee by order total
  ///                    (e.g. free over $50). Restaurant absorbs gap.
  deliveryFeeMode String @default("pass_through")
  flatDeliveryFee Float?
  /// JSON: [{ minOrderTotal: 0, customerFee: 5 }, { minOrderTotal: 50, customerFee: 0 }]
  /// Evaluated bottom-up: highest matching minOrderTotal wins.
  tieredRules     String @default("[]")

  /// Driver-pool opt-in. Separate from `enabled` because the
  /// "marketplace" add-on grants access to the pool feature but the
  /// restaurant may still want to manage their own drivers for direct
  /// orders. When true, orders default to the pool in the kitchen
  /// picker; in-store remains an explicit override.
  driverPoolEnabled Boolean @default(false)

  /// Which dispatch source the restaurant uses for delivery orders.
  ///   "own"     — restaurant's in-house drivers only. ShipDay never invoked.
  ///   "shipday" — every delivery routes to ShipDay's third-party pool.
  ///   "both"    — restaurant has both options enabled; the live choice
  ///                comes from `activeDispatchMode` (toggleable from the
  ///                kitchen display "Delivery settings" panel). Lets a
  ///                restaurant flip between in-house and pool throughout
  ///                the day based on staff availability.
  /// Default "own" so brand-new restaurants stay safe — they can flip
  /// to shipday/both after entering credentials.
  deliverySource String @default("own")

  /// When deliverySource = "both", which mode is ACTIVE right now?
  ///   "own"     — currently sending new orders to in-house drivers
  ///   "shipday" — currently sending new orders to the ShipDay pool
  /// Only consulted when deliverySource = "both"; ignored otherwise.
  /// Toggled from the kitchen display so staff can swap mid-shift
  /// (e.g. "we're slammed in-house, route to pool for the next 2 hours").
  /// Defaults to "own" — safer to keep new orders in-house by default.
  activeDispatchMode String @default("own")

  /// One-shot claim: when we emailed the Shipday partner (Justin) the intro for
  /// this restaurant. Set the first time they connect Shipday so the auto-intro
  /// fires EXACTLY once, not on every settings save. Luigi/Justin 2026-06-17.
  partnerNotifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

/// Marketplace per-restaurant monthly settlement record.
///
/// Created by the monthly settlement cron (cron/marketplace-settle) at
/// the close of each calendar month. Captures the immutable bill for
/// that period — what the restaurant accrued in per-order fees, what
/// we actually charge (capped at $249.99), and the Stripe invoice ID
/// we issued for the charge. Idempotent via (restaurantId, monthStart).
///
/// Why a separate table (not just stamping on MarketplaceListing): the
/// listing's counters reset on month rollover, so we lose the historical
/// per-month detail otherwise. This is the audit trail.
model MarketplaceSettlement {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  /// First moment of the billed month (UTC). e.g. 2026-05-01T00:00:00Z
  /// for the May 2026 settlement. The cron computes settlements for
  /// the month that just CLOSED, not the current one.
  monthStart    DateTime
  /// Order count that month, copied from the listing's counter before reset.
  ordersInMonth Int
  /// $3 × ordersInMonth, uncapped. For audit / "why was I charged X".
  accruedCents  Int
  /// What we actually invoiced: min(accruedCents, MARKETPLACE_MONTHLY_CAP_CENTS).
  invoicedCents Int

  /// Lifecycle:
  ///   "pending"  — row created, no Stripe call yet (e.g. cron in flight)
  ///   "invoiced" — stripe.invoices.create succeeded, customer must pay
  ///   "paid"     — webhook flipped this once Stripe collected the funds
  ///   "void"     — accruedCents was 0; nothing to bill, recorded for completeness
  ///   "failed"   — Stripe call errored; safe to retry by re-running cron
  status          String  @default("pending")
  stripeInvoiceId String? @unique
  failureReason   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([restaurantId, monthStart])
  @@index([status])
  @@index([monthStart])
}

// ════════════════════════════════════════════════════════════════════════
// REPORTS — GloriaFood-style analytics
// ════════════════════════════════════════════════════════════════════════
//
// All models in this section are part of the Reports system at
// /admin/reports/**. They have a HARD DATA RETENTION REQUIREMENT:
//
//   ╔══════════════════════════════════════════════════════════════════╗
//   ║ 4-YEAR RETENTION — DO NOT DELETE any row in these tables that    ║
//   ║ is less than 4 years old. No cron job, manual cleanup, or        ║
//   ║ migration is permitted to truncate / deleteMany / drop these     ║
//   ║ tables until that horizon has passed. Restaurants legally need   ║
//   ║ 4 years of sales reporting available, set by Luigi 2026-05-25.   ║
//   ╚══════════════════════════════════════════════════════════════════╝
//
// Order + OrderItem + Customer are ALSO subject to the same retention.
// Any future cleanup job that touches them must check createdAt is older
// than 4 years before deleting. There is no such job today; this comment
// exists to prevent one from being added carelessly.
//
// Archival (year 5+) goes to cold storage (Neon branch dump → S3 Glacier),
// not delete. Out of scope for the current build.
// ────────────────────────────────────────────────────────────────────────

/// Daily pre-aggregated rollup of report metrics, one row per restaurant
/// per local-calendar day. Populated by `scripts/cron/reports-snapshot.ts`
/// at 3am restaurant-local time. The Reports Dashboard reads from this
/// table for the headline cards (Today / Last 7 / Last 28) so the page
/// hits ONE row per day instead of scanning millions of Orders.
///
/// Raw Order / OrderItem tables are still the source of truth for the
/// detail views (Sales Trend chart, List View, etc) — this is purely a
/// performance layer for the dashboard summary widgets.
///
/// When `Order.deletedAt` semantics ever ship (they don't today), the
/// snapshot rebuilder must respect them. Until then, "completed orders"
/// is the canonical metric — rejected / pending exclude.
model ReportDailySnapshot {
  id               String   @id @default(cuid())
  restaurantId     String
  /// Local-calendar date for this rollup. Stored at midnight UTC of the
  /// restaurant's TZ-adjusted day so equality checks are simple. The
  /// cron job is responsible for the TZ conversion.
  date             DateTime
  /// Sum of `Order.total` for orders with status="completed" on this day.
  revenueCents     Int      @default(0)
  /// Count of orders placed (regardless of status) on this day.
  orderCount       Int      @default(0)
  /// Count of orders that reached status="completed" on this day.
  completedCount   Int      @default(0)
  /// Count of orders that were rejected/cancelled on this day.
  rejectedCount    Int      @default(0)
  /// Distinct customer count (by Customer.id) ordering on this day.
  customerCount    Int      @default(0)
  /// Of `customerCount`, how many are first-time (no prior Order in
  /// this restaurant). Returning = customerCount - newCustomerCount.
  newCustomerCount Int      @default(0)
  /// Average order value in cents (revenueCents / completedCount,
  /// stored pre-computed to skip the divide-by-zero guard at read time).
  avgOrderCents    Int      @default(0)
  /// JSON breakdown: { "delivery": 12, "pickup": 8, "dine_in": 0 }
  typeBreakdown    String?
  /// JSON breakdown: { "direct": 15, "marketplace": 5, "email": 0, ... }
  channelBreakdown String?
  /// JSON breakdown: { "card": 18, "cash": 2 }
  paymentBreakdown String?
  /// Timestamp the cron last (re)built this row. Used for "stale"
  /// detection — if a snapshot is older than 25 hours and today's date
  /// is newer, we trigger an on-demand rebuild.
  builtAt          DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  // One row per restaurant per day.
  @@unique([restaurantId, date])
  // Dashboard reads: "last N days for restaurant X".
  @@index([restaurantId, date])
}

/// Append-only log of website visits to the customer-facing order page,
/// hosted marketing site, and widget embeds. Powers:
///   - Reports → Online Ordering → Website Funnel
///   - Reports → Online Ordering → Website Visits
///   - Conversion-rate calculation (visits ÷ orders)
///
/// Written by a lightweight beacon endpoint `/api/track/visit` called
/// once per session-start. Sessions are identified by an httpOnly
/// cookie set on first hit. NO PII — we don't store name/email/IP;
/// just the channel/referrer/landing-path + a hashed session id.
///
/// Retention: same 4-year rule as the rest of Reports.
model WebsiteVisit {
  id           String   @id @default(cuid())
  restaurantId String
  /// Hashed session identifier. Same hash across all events in one
  /// session so we can build the funnel. Reset on new tab / cleared
  /// cookies.
  sessionHash  String
  /// Marketing channel, from the same enum as `Order.channel`:
  /// "direct" | "marketplace" | "email" | "organic" | "paid_ads"
  /// | "social_media" | "referral" | "affiliate" | "internal"
  /// Defaults "direct" when no source signal is present.
  channel      String   @default("direct")
  /// Document.referrer at landing time, truncated to 255 chars.
  /// Powers the "From inside your website" segmentation when the
  /// referrer hostname matches the restaurant's own domain.
  referrer     String?
  /// utm_campaign / utm_source / utm_medium combined, opaque.
  /// 255-char cap. Optional.
  utm          String?
  /// First page hit in the session ("/order/luigis", "/about", etc).
  landingPath  String?
  /// "desktop" | "mobile" | "tablet". Derived from user-agent.
  deviceType   String?
  /// ISO 3166-1 alpha-2 country code if we can derive it from the
  /// Vercel geolocation header. Null in dev / unknown.
  country      String?
  /// Marketing Studio smart-link code (Luigi 2026-06-10): the /m/<code> redirect
  /// appends ?ref=<code>; resolved to the SmartLink at order-create for per-link
  /// scan→order attribution. Null for organic / non-link visits.
  refCode      String?
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  // Date-range scans (the heavy report query).
  @@index([restaurantId, createdAt])
  // Funnel join from event to visit.
  @@index([sessionHash])
  // "By channel" pivot.
  @@index([restaurantId, channel, createdAt])
}

/// Marketing Studio (Luigi 2026-06-10). A trackable short link: /m/<code> 302s
/// to the restaurant's ordering page (with ?ref=<code> + utm) and counts the
/// scan. When a visit carrying that ref later places an order, the order/revenue
/// counters bump (idempotently, via Order.smartLinkCounterApplied). Denormalized
/// counters give O(1) dashboard reads; SmartLinkScan keeps the time-series.
model SmartLink {
  id           String   @id @default(cuid())
  restaurantId String
  /// GLOBALLY unique — the /m/<code> URL carries no restaurant context, so the
  /// code alone must resolve the link. Generated base62 with retry-on-conflict.
  code         String   @unique
  name         String
  /// Path on the PRIMARY platform domain the scan lands on (default: the
  /// restaurant's order page). Links never use a tenant host (the proxy would
  /// rewrite /m/<code> into /order/<slug>/m/<code> and 404).
  targetPath   String
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  /// Coarse channel hint surfaced to the existing visit channel detector.
  channelHint  String?
  scanCount    Int      @default(0)
  orderCount   Int      @default(0)
  revenueCents Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  scans      SmartLinkScan[]
  assets     MarketingAsset[]

  @@index([restaurantId])
}

/// One scan/click of a SmartLink — the time-series behind the scans chart.
/// Inserted fire-and-forget (after the redirect flushes) so it never blocks /m.
model SmartLinkScan {
  id          String   @id @default(cuid())
  smartLinkId String
  /// Reserved: a scan happens BEFORE landing, so we usually can't stitch it to a
  /// session yet. Kept for a future scan→visit join. Null in v1.
  sessionHash String?
  scannedAt   DateTime @default(now())

  smartLink SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)

  @@index([smartLinkId, scannedAt])
}

/// A saved marketing asset (flyer / poster). `designJson` holds the OWNER's
/// inputs (template id, headline, offer text, chosen smart link) — branding
/// (logo, colours, name, address) + the QR are pulled LIVE at render so the
/// asset always reflects current branding. Printed via a window.print() page.
model MarketingAsset {
  id           String   @id @default(cuid())
  restaurantId String
  type         String // "flyer" | "poster"
  name         String
  smartLinkId  String?
  designJson   String   @default("{}")
  previewUrl   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  smartLink  SmartLink? @relation(fields: [smartLinkId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
}

/// Append-only log of meaningful customer-journey events that pair with
/// `WebsiteVisit`. Each event references a `sessionHash` so the funnel
/// query joins by session. Events we track:
///
///   "visit"          — entered the ordering page (same trigger as
///                      WebsiteVisit; logged for funnel uniformity)
///   "menu_browsed"   — scrolled past the menu fold OR clicked any item
///   "item_added"     — first item added to cart
///   "checkout_open"  — opened the checkout drawer
///   "checkout_info"  — filled customer details
///   "payment_open"   — reached the payment step
///   "order_placed"   — successfully POSTed /api/orders (terminal)
///
/// The funnel report renders these as a sankey-ish bar chart with
/// drop-off percentages.
model WebsiteFunnelEvent {
  id           String   @id @default(cuid())
  restaurantId String
  sessionHash  String
  step         String
  /// Optional: the menuItemId / orderId being acted on for item_added
  /// and order_placed events. Lets the Menu Insights report cross-ref
  /// which items are reached but never purchased ("abandoned" items).
  targetId     String?
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, createdAt])
  @@index([sessionHash])
  @@index([restaurantId, step, createdAt])
}

/// Append-only log of individual menu-item views (when the customer
/// scrolls past or clicks into a menu item on the order page). Powers
/// Reports → Menu Insights → Items "Views" column, which lets owners
/// see which items are seen-but-not-ordered (= bad copy / photo / price).
///
/// Volume is higher than WebsiteVisit (one row per item per session
/// roughly), so we expect this to be the biggest reports table. The
/// (restaurantId, createdAt) index keeps date-range scans fast; without
/// it a busy restaurant's 4-year history would be unsearchable.
model MenuItemView {
  id           String   @id @default(cuid())
  restaurantId String
  menuItemId   String
  sessionHash  String
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@index([restaurantId, createdAt])
  @@index([menuItemId, createdAt])
  @@index([sessionHash])
}

/// Append-only log of online/offline transitions for kitchen devices.
/// SPARSE — only writes when state changes (offline→online or online→
/// offline), not every heartbeat tick. The Reports Connectivity Health
/// chart replays these events to compute per-minute coverage.
///
/// Trade-off vs the obvious "log every heartbeat" approach: at 4-second
/// poll × 10,000 restaurants × 4 years that's ~32 BILLION rows. Logging
/// transitions only puts it at ~10 rows/restaurant/day worst case —
/// orders of magnitude smaller and the visualization is identical.
///
/// The "current state" lives on KitchenDevice.lastSeenAt (already there);
/// this table is the audit trail. Writer logic lives in
/// `src/lib/kitchen/heartbeat.ts:recordHeartbeat()` and only inserts a
/// row when (now - lastSeenAt) crosses the offline threshold (60s).
model ConnectivityEvent {
  id           String   @id @default(cuid())
  restaurantId String
  /// Device-stable hash from KitchenDevice.deviceHash. Multiple devices
  /// per restaurant supported (kitchen + bar + drive-thru terminals).
  deviceHash   String
  /// "offline" | "online"
  eventType    String
  occurredAt   DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, occurredAt])
  @@index([restaurantId, deviceHash, occurredAt])
}

/// ─────────────────────────────────────────────────────────────────────
/// Reseller Reports & Requests (Luigi 2026-06-02)
/// ─────────────────────────────────────────────────────────────────────
/// Hidden, auth-gated bug tracker / feature request hub. Replaces the
/// FeeFree-Bug-Tracker-v3.xlsx workflow that was getting unwieldy.
///
/// Access model:
///   - Superadmin: full read/write, can change status, can invite/revoke.
///   - Invited resellers (email in ResellerReportInvite): can read all
///     reports, create new ones, comment on any. Cannot change status.
///   - Anyone else: 404.
///
/// Status flow is enforced server-side — only superadmin PATCHes the
/// status field. Resellers see the current status as a read-only badge.

model ResellerReport {
  id              String   @id @default(cuid())
  title           String
  /// Markdown allowed. Rendered as plain text on the list view, with
  /// basic newline preservation on the detail view. We deliberately
  /// don't ship a rich text editor — the tracker is meant to be
  /// fast, not polished.
  body            String
  /// One of: BUG | FEATURE_REQUEST | FEATURE_ADJUSTMENT | FEATURE_UPDATE | FEATURE_FIX
  /// Drives the type badge color on the list + detail view.
  type            String
  /// One of: NEW | IN_PROGRESS | IN_TESTING | FIXED | WONT_FIX
  /// Defaults to NEW on creation. Only superadmin can change it.
  status          String   @default("NEW")
  /// One of: LOW | MEDIUM | HIGH | CRITICAL
  /// Defaults to MEDIUM. Optional — used for sorting the table.
  priority        String   @default("MEDIUM")
  /// Identity of the person who filed the report. Stored verbatim (not
  /// as a foreign key) so the report survives reseller account deletion.
  authorEmail     String
  authorName      String
  /// "Reported by" — distinct from `author*` so the superadmin can file
  /// a report on behalf of a reseller (Luigi 2026-06-02 spec). When
  /// null, callers should fall back to authorEmail/authorName. Set
  /// only when the form was filed by someone other than the actual
  /// person who reported the issue.
  reportedByEmail String?
  reportedByName  String?
  /// JSON-encoded string array of image URLs (Vercel Blob URLs in prod,
  /// /uploads/... in local dev). Screenshots attached at report creation
  /// time. Null/missing = no attachments; "[]" also means none. We use a
  /// string column for cross-DB portability (matches how availableDays
  /// is stored elsewhere in this schema).
  imageUrls       String?
  /// SUPERADMIN-ONLY AI triage analysis (markdown). Generated by Claude
  /// from the raw report on first superadmin view — restructures the
  /// report, suggests type/severity, flags the likely affected area, and
  /// proposes a solution direction. NEVER sent to reseller browsers (the
  /// detail page only threads this prop through when canChangeStatus).
  /// Null = not analyzed yet. See src/lib/reseller-reports-ai.ts.
  aiAnalysis      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  comments      ResellerReportComment[]
  verifications ResellerReportVerification[]
  upvotes       ResellerReportUpvote[]
  activity      ResellerReportActivity[]
  seen          ResellerReportSeen[]

  @@index([status, createdAt])
  @@index([type])
  @@index([authorEmail])
}

/// In-app notification feed for the reseller platform (+ superadmin). One row
/// per recipient per event — e.g. "X replied to your report", "status changed".
/// Created alongside the existing notification emails. The recipient sees a
/// bell-style unread count + a feed; rows are marked read on view. Luigi 2026-06-05.
model ResellerNotification {
  id             String    @id @default(cuid())
  /// Lowercased recipient email (matches reseller / SA login email).
  recipientEmail String
  /// "report_comment" | "report_status" — drives the icon/copy.
  kind           String
  title          String
  body           String?
  /// Where clicking the notification navigates (e.g. /reseller-reports/<id>).
  linkUrl        String?
  /// Loose ref to the source report (no FK so report deletion can't orphan-fail).
  reportId       String?
  actorName      String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([recipientEmail, readAt])
  @@index([recipientEmail, createdAt])
}

/// Per-viewer "last seen" marker for the in-app new-activity badge. One row
/// per (report, viewer email). A report shows a NEW badge for a viewer when
/// its updatedAt is newer than their seenAt (or they have no row yet). Marked
/// seen when the viewer opens the report, comments, or changes its status.
/// Luigi 2026-06-05.
model ResellerReportSeen {
  id          String         @id @default(cuid())
  reportId    String
  viewerEmail String
  seenAt      DateTime       @default(now())
  report      ResellerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, viewerEmail])
  @@index([viewerEmail])
}

/// Verification poll. Once a report is marked IN_TESTING / FIXED any
/// person with access can cast a single vote — "still working" or
/// "still broken". The reporter's vote is visually prominent on the
/// detail page so a "fixed by Luigi → confirmed working by the
/// reseller who reported it" loop is visible at a glance.
model ResellerReportVerification {
  id         String   @id @default(cuid())
  reportId   String
  /// Lowercased email of the voter. Acts as the per-report identity —
  /// one vote per person; flipping vote updates the row in place.
  voterEmail String
  voterName  String
  /// "WORKING" | "NOT_WORKING".
  vote       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  report ResellerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, voterEmail])
  @@index([reportId])
}

/// "Me too" upvotes. Lets resellers signal "I hit this too" without
/// filing a duplicate report. Severity at a glance: a report with 8
/// upvotes is more urgent than one with 0.
model ResellerReportUpvote {
  id         String   @id @default(cuid())
  reportId   String
  voterEmail String // lowercased
  voterName  String
  createdAt  DateTime @default(now())

  report ResellerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, voterEmail])
  @@index([reportId])
}

/// Append-only audit log per report. Auto-written by the API layer on:
///   CREATED | STATUS_CHANGE | PRIORITY_CHANGE | VERIFIED_WORKING |
///   VERIFIED_BROKEN | VERIFICATION_REMOVED | UPVOTED | UNUPVOTED |
///   COMMENTED
/// Renders as a timeline on the detail page so the conversation +
/// state history is visible in one place (nolt.io-style activity log).
model ResellerReportActivity {
  id         String   @id @default(cuid())
  reportId   String
  actorEmail String
  actorName  String
  kind       String
  /// Free-form detail — e.g. "NEW → IN_PROGRESS" or empty for "UPVOTED".
  detail     String?
  createdAt  DateTime @default(now())

  report ResellerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model ResellerReportComment {
  id          String   @id @default(cuid())
  reportId    String
  authorEmail String
  authorName  String
  body        String
  /// JSON-encoded string array of image URLs. Same shape as
  /// ResellerReport.imageUrls — comments can attach screenshots too
  /// (e.g. "here's what I see after the fix").
  imageUrls   String?
  createdAt   DateTime @default(now())

  report ResellerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
}

model ResellerReportInvite {
  id          String   @id @default(cuid())
  /// Email of the reseller who can access /reseller-reports. Lowercased
  /// at write time so case-insensitive matching just works.
  email       String   @unique
  /// Optional human-readable name shown in the invites table.
  displayName String?
  invitedAt   DateTime @default(now())
  /// User.id of the superadmin who created the invite. We don't FK this
  /// because the User table may move under us and the invite shouldn't
  /// vanish if an admin account is removed.
  invitedById String
}

/// A registered kitchen device (phone/tablet running the native Kitchen Order
/// App) that should receive a PUSH notification when a new order arrives — so
/// staff are alerted even with the screen off / app backgrounded. One row per
/// FCM (Android) / APNs-via-FCM (iOS) token. Dead tokens are pruned when FCM
/// reports them unregistered; a device re-registers (upsert) on every launch,
/// refreshing lastSeenAt. No relation back to Restaurant (a hot, large table)
/// — restaurantId + index is enough and keeps device writes cheap.
/// Push notifications. Named KitchenPushToken (not KitchenDevice — that model
/// already exists for device fingerprinting). Luigi 2026-06-15.
model KitchenPushToken {
  id           String   @id @default(cuid())
  restaurantId String
  /// FCM/APNs registration token. Unique so a re-register upserts in place.
  token        String   @unique
  /// "android" | "ios" | "web" — drives platform-specific payload tweaks.
  platform     String   @default("android")
  createdAt    DateTime @default(now())
  /// Refreshed on every app launch; lets a future cron prune long-silent devices.
  lastSeenAt   DateTime @default(now())

  @@index([restaurantId])
}
