model AutopilotCampaign {
  id           String   @id @default(cuid())
  restaurantId String
  campaignType String // second_order | cart_abandonment | reengagement
  isEnabled    Boolean  @default(false)
  subject      String   @default("")
  emailBody    String   @default("")
  delayHours   Int      @default(24)
  couponId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  restaurant Restaurant      @relation(fields: [restaurantId], references: [id])
  sends      AutopilotSend[]

  @@unique([restaurantId, campaignType])
}

/// Tracks which autopilot emails have been sent to which customers, so
/// the cron doesn't double-send when it runs every hour. Unique on
/// (campaignId, customerEmail, sequence) makes attempted double-sends a
/// constraint violation that the runner catches + ignores — defense-in-depth
/// in case two cron instances fire close together. Email is the de-dup key
/// rather than customerId because a customer may have multiple Customer
/// rows (one per restaurant they've ordered from) but only one inbox.
///
/// `sequence` is the drip-ladder step number (Luigi 2026-06-10): a single-send
/// (legacy / cart-abandon) is sequence 0; a stepped re-engagement send is
/// 1..N. Including it in the unique key lets one customer receive each step of
/// a multi-email win-back sequence exactly once, while still blocking true
/// double-sends of the SAME step.
model AutopilotSend {
  id            String   @id @default(cuid())
  campaignId    String
  customerEmail String
  /// Optional FK to a specific Customer row for the restaurant — handy
  /// for analytics but not the de-dup key (see comment above).
  customerId    String?
  /// Drip-sequence step this send was for. 0 = single-send (legacy). 1..N =
  /// the Nth email of a multi-step win-back ladder.
  sequence      Int      @default(0)
  sentAt        DateTime @default(now())

  campaign AutopilotCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, customerEmail, sequence])
  @@index([campaignId])
  /// Batch the per-run "who already got which step?" lookup (campaign + email).
  @@index([campaignId, customerEmail])
}

/// One configurable step of an Autopilot drip sequence (Luigi 2026-06-10).
/// A campaign (e.g. "reengagement") can have several of these — each its own
/// follow-up email with its own delay + discount %, forming an escalating
/// win-back ladder that stops the moment the customer re-orders. Sparse,
/// owner-edited email copy lives here (a side table) rather than bloating the
/// hot Promotion table. The discount % is mirrored to the matching
/// campaignSequence Promotion row, which is what the email advertises + the
/// ordering page applies, so the two can never drift.
///   delayHours      — measured from the trigger event (last order for
///                     reengagement, first order for second_order).
///   discountPercent — drives Promotion.ruleConfig.discountPercent for the
///                     row whose campaignSequence == stepNumber.
model AutopilotStep {
  id              String   @id @default(cuid())
  restaurantId    String
  campaignType    String // second_order | reengagement | cart_abandonment
  stepNumber      Int // 1-based position in the ladder
  delayHours      Int      @default(168)
  discountPercent Int      @default(0)
  subject         String   @default("")
  emailBody       String   @default("")
  isEnabled       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, campaignType, stepNumber])
  @@index([restaurantId, campaignType])
}

model ReservationSettings {
  id                 String   @id @default(cuid())
  restaurantId       String   @unique
  /// Deprecated: prefer minNoticeMinutes for new code. Kept as a fallback
  /// for legacy rows where minNoticeMinutes is null. The UI saves both
  /// fields in sync (minNoticeMinutes = source of truth; minNoticeHours
  /// = floor(minutes / 60) for older readers).
  minNoticeHours     Int      @default(2)
  /// Minimum time (in minutes) a reservation must be booked in advance.
  /// GloriaFood-style booking rules use minutes precision (e.g. "15 min,
  /// 30 min, 1 hr") rather than the integer hours the original schema
  /// supported. Default 120 min = 2 hours = the legacy default.
  minNoticeMinutes   Int      @default(120)
  maxAdvanceDays     Int      @default(30)
  slotLengthMinutes  Int      @default(30)
  maxPerSlot         Int      @default(10)
  minGuests          Int      @default(1)
  maxGuests          Int      @default(20)
  autoConfirm        Boolean  @default(true)
  allowPreOrder      Boolean  @default(false)
  holdMinutes        Int      @default(15)
  requireDeposit     Boolean  @default(false)
  depositAmount      Float    @default(0)
  cancellationPolicy String   @default("")
  reservationHours   String   @default("{}") // JSON: { "0": { open: "10:00", close: "22:00", enabled: true } }
  blackoutDates      String   @default("[]") // JSON: ["2024-12-25"]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

model ReservationTable {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  number       Int?
  section      String?
  capacity     Int      @default(4)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  reservations Reservation[]

  @@index([restaurantId])
}

model Reservation {
  id                        String    @id @default(cuid())
  restaurantId              String
  tableId                   String?
  orderId                   String?
  confirmationCode          String
  status                    String    @default("pending") // pending | confirmed | seated | completed | cancelled | rejected | no_show
  customerName              String
  customerEmail             String?
  customerPhone             String?
  partySize                 Int
  date                      String // "YYYY-MM-DD"
  time                      String // "HH:MM"
  durationMinutes           Int       @default(90)
  notes                     String?
  staffNotes                String?
  /// Mirrors Order.rejectionReason. Stamped "Auto-rejected: ..." when a PENDING
  /// booking is auto-declined for not being accepted within its window (the
  /// kitchen "MISSED" case). A manual staff decline leaves this null. The
  /// kitchen badge + the customer email branch on this so an un-attended booking
  /// reads MISSED, never REJECTED/declined. Additive nullable column — cheap.
  /// Luigi 2026-06-16.
  rejectionReason           String?
  /// Per-tab kitchen "Clear" flags — a walk-up booking shows in the All and
  /// Complete tabs just like an order, so it needs the SAME independent per-tab
  /// clear flags an Order has, plus its own Reservations-tab flag. Clearing one
  /// tab never affects another; the booking itself is never deleted. Luigi
  /// 2026-06-08 (All/Complete) — 2026-06-04 (Reservations).
  clearedFromReservationsAt DateTime?
  clearedFromAllAt          DateTime?
  clearedFromCompleteAt     DateTime?
  depositAmount             Float     @default(0)
  depositPaid               Boolean   @default(false)
  preOrderTotal             Float     @default(0)
  paymentIntentId           String?
  /// When set + in the future, the kitchen treats this booking as "parked": it
  /// shows (highlighted, calm) but does NOT ring until this moment. Stamped =
  /// nextOpenAt() when a reservation lands while the restaurant is CLOSED, so an
  /// overnight booking rings at opening — exactly like takeaway/delivery orders —
  /// instead of waking the kitchen. Null = ring immediately. Luigi 2026-06-14.
  alertAt                   DateTime?
  /// Idempotency stamp for the "missed reservation" auto-call (mirrors
  /// Order.alertCallAt). Set when we place the warning call so the cron never
  /// double-dials. Luigi 2026-06-15.
  alertCallAt               DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  restaurant Restaurant        @relation(fields: [restaurantId], references: [id])
  table      ReservationTable? @relation(fields: [tableId], references: [id])

  @@index([restaurantId, date])
  @@index([restaurantId, status])
}

model ServiceFee {
  id                 String   @id @default(cuid())
  restaurantId       String
  name               String
  feeType            String // "fixed" | "percent"
  amount             Float
  appliesTo          String   @default("both") // "pickup" | "delivery" | "both"
  daysOfWeek         String? // CSV "0,5,6" — null = every day
  publicHolidaysOnly Boolean  @default(false)
  countryCode        String   @default("US")
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

/// Fiscal / billing identity the restaurant provides for proof-of-purchase
/// on their platform-service invoices (subscriptions + add-ons). Synced to
/// the platform Stripe customer (name / email / address / VAT tax id) so it
