generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  slogan             String?
  description        String?
  phone              String?
  email              String?
  address            String?
  city               String?
  state              String?
  zip                String?
  country            String   @default("US")
  timezone           String   @default("America/New_York")
  cuisineType        String?
  logoUrl            String?
  bannerUrl          String?
  isActive           Boolean  @default(true)
  acceptsPickup      Boolean  @default(true)
  acceptsDelivery    Boolean  @default(false)
  acceptsDineIn      Boolean  @default(false)
  acceptsCatering    Boolean  @default(false)
  acceptsTakeOut     Boolean  @default(false)
  acceptsReservations Boolean  @default(false)
  serviceSettings    String?  // JSON: per-service { displayName, description, estimatedTime }
  minimumOrder       Float    @default(0)
  deliveryFee        Float    @default(0)
  estimatedPickup    Int      @default(20)
  estimatedDelivery  Int      @default(45)
  taxRate            Float    @default(0)
  // Stripe Connect (Layer C — restaurant collects payments from customers)
  stripeAccountId       String?
  stripeAccountStatus   String? @default("not_connected")
  stripeChargesEnabled  Boolean @default(false)
  stripePayoutsEnabled  Boolean @default(false)

  // Platform subscription (Layer B — restaurant pays you monthly via Stripe Checkout)
  subscriptionPlanId      String?
  trialEndsAt             DateTime?
  subscriptionStatus      String   @default("trialing")   // trialing | active | past_due | cancelled | incomplete | expired
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   @unique
  currentPeriodEnd        DateTime?
  cancelAtPeriodEnd       Boolean   @default(false)
  reviewLink         String?
  infoContent        String?  // JSON for info page custom CTAs etc
  themeSettings      String?  // JSON for customer-facing website theme
  lat                Float?   // geocoded restaurant latitude
  lng                Float?   // geocoded restaurant longitude
  mapProvider        String   @default("leaflet")  // "leaflet" | "google"
  googleMapsApiKey   String?  // only used when mapProvider = "google"
  autoAcceptOrders   Boolean  @default(false)
  defaultLanguage    String   @default("en")
  socialLinks        String?  // JSON: { instagram, facebook, tiktok, x, youtube, linkedin, pinterest, snapchat, threads, whatsapp, yelp, googleBusiness, tripadvisor, website }
  marketingTier      String   @default("free") // "free" | "social_basic" | "social_pro" | "social_managed" — gates AI-post / scheduling features

  // Domain routing: "subdomain" → <sub>.<PLATFORM_DOMAIN>, "customDomain" → bring-your-own.
  // slug stays internal-stable (used by /order/[slug] paths and order references);
  // subdomain is the marketing-changeable label the customer sees in their address bar.
  subdomain            String?  @unique
  customDomain         String?  @unique
  customDomainStatus   String   @default("none")  // none | pending | verifying | verified | error
  customDomainAddedAt  DateTime?
  customDomainError    String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  subscriptionPlan SubscriptionPlan?  @relation(fields: [subscriptionPlanId], references: [id])
  users            User[]
  menuCategories   MenuCategory[]
  menuItems        MenuItem[]
  modifierGroups   ModifierGroup[]
  orders           Order[]
  customers        Customer[]
  coupons          Coupon[]
  deliveryZones    DeliveryZone[]
  openingHours     OpeningHours[]
  receiptTemplates ReceiptTemplate[]
  promotions         Promotion[]
  printerSettings    PrinterSettings?
  autopilotCampaigns   AutopilotCampaign[]
  paymentProvider      PaymentProvider?
  printLogs            PrintLog[]
  reservationSettings  ReservationSettings?
  reservationTables    ReservationTable[]
  reservations         Reservation[]
  notificationRecipients NotificationRecipient[]
  serviceFees          ServiceFee[]
  subscriptionInvoices SubscriptionInvoice[]

  // Reseller Partner Program — set at restaurant creation when the signup
  // carried a ?ref=<referralCode> from an approved reseller. Nullable: most
  // restaurants are direct, not reseller-sourced. Only superadmin can reassign
  // (support cases). On reseller deletion → SetNull so the restaurant stays.
  resellerProfileId    String?
  resellerProfile      ResellerProfile? @relation(fields: [resellerProfileId], references: [id], onDelete: SetNull)
  restaurantAccess     RestaurantAccess[]
  commissions          CommissionTransaction[]

  // Multi-location: a child Restaurant points its parentRestaurantId at the
  // brand's "primary" Restaurant. Nullable — existing restaurants stay
  // top-level (parent = null). Each location bills/operates independently;
  // the parent link only drives UX (location switcher, "add another location"
  // button in the admin sidebar).
  parentRestaurantId   String?
  parentRestaurant     Restaurant?  @relation("Locations", fields: [parentRestaurantId], references: [id], onDelete: SetNull)
  childLocations       Restaurant[] @relation("Locations")

  // Customer-side email toggles (single set per restaurant)
  customerEmailPickupReady   Boolean @default(true)
  customerEmailDeliveryReady Boolean @default(true)
  customerEmailDineInReady   Boolean @default(false)
  customerEmailOrderRejected Boolean @default(true)
  customerEmailOrderConfirm  Boolean @default(true)

  // Publishing / setup state (Phase 1 of the GloriaFood-style redesign).
  // publishedAt is null until the owner finishes required setup and clicks
  // "Publish" — only then does the Legacy Website widget render and the
  // /order/<slug> page accept real customers. Existing restaurants get this
  // field auto-populated by scripts/migrate-to-free-plan.ts so nothing breaks.
  publishedAt          DateTime?
  ownerEmailVerifiedAt DateTime?
  /// Opaque public ID used by the widget embed snippet so the embed URL
  /// doesn't leak the slug. Generated lazily on first publish (Phase 3).
  widgetPublicId       String?   @unique

  addOns               RestaurantAddOn[]
  kitchenDevices       KitchenDevice[]
  locationInvites      LocationInvite[]

  @@index([resellerProfileId])
  @@index([parentRestaurantId])
  @@index([publishedAt])
}

/// Brand → location invite tokens. When a multi-location brand owner wants
/// to add a new location, they generate one of these rows (via the brand
/// admin dashboard). The recipient receives an email with a signup link
/// containing `?invite=<token>`. Completing signup creates a fresh
/// Restaurant + User, parented under the brand. Tokens are single-use.
model LocationInvite {
  id                   String   @id @default(cuid())
  brandId              String
  brand                Restaurant @relation(fields: [brandId], references: [id], onDelete: Cascade)
  token                String   @unique
  email                String?  // pre-fill on signup form (optional, owner's choice)
  suggestedName        String?  // suggested location name (e.g. "Brooklyn Branch")
  createdByUserId      String   // userId of the brand admin who created the invite
  acceptedAt           DateTime?
  acceptedRestaurantId String?  // restaurant created by accepting this invite
  expiresAt            DateTime // 30 days from creation by default
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([brandId])
  @@index([token])
  @@index([expiresAt])
}

/// Tracks each kitchen PWA install (or kitchen-staff session) that has
/// checked in via the heartbeat endpoint. The publishing checklist's
/// "Order-taking app connected" step is satisfied when at least one row
/// exists for the restaurant whose lastSeenAt is within the freshness
/// window. The device "id" is a stable hash the kitchen page sends from
/// localStorage on every poll — not an authoritative identity, just a
/// best-effort presence signal.
model KitchenDevice {
  id           String   @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  /// Stable random ID generated by the kitchen page on first load and
  /// persisted in localStorage. Used to dedupe the same device polling
  /// repeatedly so we update one row instead of inserting many.
  deviceHash   String
  /// Free-form label the owner sets in the admin (e.g. "Front counter").
  label        String?
  userAgent    String?
  lastSeenAt   DateTime @default(now())
  firstSeenAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, deviceHash])
  @@index([restaurantId])
  @@index([lastSeenAt])
}

model NotificationRecipient {
  id            String   @id @default(cuid())
  restaurantId  String
  email         String
  name          String?
  isActive      Boolean  @default(true)
  emailLanguage String   @default("en")

  // Confirmation events
  deliveryConfirmed         Boolean @default(true)
  pickupConfirmed           Boolean @default(true)
  tableReservationConfirmed Boolean @default(true)
  orderAheadConfirmed       Boolean @default(true)
  dineInConfirmed           Boolean @default(true)

  // Operational events
  orderPlaced    Boolean @default(true)
  orderAccepted  Boolean @default(true)
  orderRejected  Boolean @default(true)
  orderCanceled  Boolean @default(true)
  orderMissed    Boolean @default(true)
  orderNotPlaced Boolean @default(true)

  // System events
  lowBattery       Boolean @default(true)
  badInternet      Boolean @default(true)
  endOfDayReport   Boolean @default(true)
  endOfMonthReport Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Float    // monthly USD price; cents on Stripe side
  interval    String   @default("month")  // month | year
  description String?
  features    String   // JSON-encoded array of feature bullets
  isActive    Boolean  @default(true)

  // Stripe sync state — Product is reused across price changes; Prices are
  // immutable so any `price` edit creates a NEW stripePriceId. Old Prices
  // stay archived (active=false on Stripe) so existing subscribers keep
  // their grandfathered rate until we explicitly migrate them.
  stripeProductId String? @unique
  stripePriceId   String? @unique
  syncStatus      String  @default("not_synced") // not_synced | syncing | synced | error
  syncError       String?
  syncedAt        DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  restaurants Restaurant[]
}

// Audit trail of every invoice Stripe sends for a restaurant's platform
// subscription. Webhook handlers upsert into this table on invoice.paid /
// invoice.payment_failed events. Keyed by stripeInvoiceId for idempotency.
model SubscriptionInvoice {
  id                   String    @id @default(cuid())
  restaurantId         String
  stripeInvoiceId      String    @unique
  stripeSubscriptionId String?
  amountPaid           Int       // in cents
  amountDue            Int       @default(0) // in cents
  currency             String    @default("usd")
  status               String    // paid | open | uncollectible | void | draft
  paidAt               DateTime?
  periodStart          DateTime?
  periodEnd            DateTime?
  hostedInvoiceUrl     String?
  invoicePdfUrl        String?
  receiptUrl           String?
  attemptCount         Int       @default(0)
  createdAt            DateTime  @default(now())

  // Refund/dispute tracking — read by the commission engine. Initially 0/false
  // on creation; updated by charge.refunded / charge.dispute.created webhook
  // handlers when the underlying charge is reversed.
  amountRefundedCents  Int       @default(0)
  disputed             Boolean   @default(false)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  commission CommissionTransaction?

  @@index([restaurantId])
  @@index([stripeSubscriptionId])
}

// Idempotency log — every Stripe webhook event we've successfully processed.
// On retry, we look up by stripeEventId and short-circuit.
model StripeWebhookEvent {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique
  eventType       String
  receivedAt      DateTime @default(now())
  processedAt     DateTime?
  status          String   @default("received") // received | processed | failed | ignored
  errorMessage    String?

  @@index([eventType])
  @@index([receivedAt])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("restaurant_admin")
  restaurantId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Phase 1 of the signup-redesign: set when the owner clicks the verify
  /// link from their welcome email. Required for publishing (Phase 3 wires
  /// the actual gate; this field exists earlier so we can mark existing
  /// restaurants as already-verified via the migration script).
  emailVerifiedAt  DateTime?
  emailVerifyToken String?   @unique

  restaurant  Restaurant?           @relation(fields: [restaurantId], references: [id])
  resetTokens PasswordResetToken[]
  resellerProfile  ResellerProfile?     // present only on reseller_partner users
  restaurantAccess RestaurantAccess[]   // non-owner restaurant grants
}

// Singleton row holding platform-wide settings (Resend API key, etc.).
// Only the super admin can read/write. Secrets are AES-256-GCM encrypted at rest.
model PlatformSettings {
  id              String   @id @default("singleton")
  // Resend (email) — encrypted key, plain envelope (iv + auth tag)
  resendApiKeyEnc String?
  resendApiKeyIv  String?
  resendApiKeyTag String?
  emailFrom       String?  // e.g. "Fee Free Ordering <hello@yourdomain.com>"
  // Stripe — secret key + webhook secret encrypted at rest. Publishable key
  // is stored plain (safe to expose to clients). When any of these are null
  // we fall back to the matching env var (STRIPE_SECRET_KEY etc.).
  stripeMode             String?  // "test" | "live"
  stripeEnabled          Boolean  @default(false)
  stripePublishableKey   String?
  stripeSecretKeyEnc     String?
  stripeSecretKeyIv      String?
  stripeSecretKeyTag     String?
  stripeWebhookSecretEnc String?
  stripeWebhookSecretIv  String?
  stripeWebhookSecretTag String?
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MenuCategory {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  imageUrl     String?
  isActive     Boolean  @default(true)
  isHidden     Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  menuItems      MenuItem[]
  modifierGroups ModifierGroup[]

  @@index([restaurantId, isActive])
}

model MenuItem {
  id             String   @id @default(cuid())
  restaurantId   String
  categoryId     String
  name           String
  description    String?
  price          Float
  imageUrl       String?
  isAvailable    Boolean  @default(true)
  isFeatured     Boolean  @default(false)
  isSoldOut      Boolean  @default(false)
  isHidden       Boolean  @default(false)
  hasVariants    Boolean  @default(false)
  forPickup      Boolean  @default(true)
  forDelivery    Boolean  @default(true)
  availableDays  String?  // JSON: [0,1,2,3,4,5,6] — null = all days
  availableFrom  String?  // "HH:MM"
  availableTo    String?  // "HH:MM"
  sortOrder      Int      @default(0)
  calories       Int?
  allergens      String?
  pizzaConfig    String?  // JSON: PizzaConfig — marks item as a pizza builder item
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  category       MenuCategory    @relation(fields: [categoryId], references: [id])
  variants       ItemVariant[]
  modifierGroups ModifierGroup[]
  orderItems     OrderItem[]

  @@index([restaurantId, isAvailable])
  @@index([categoryId, sortOrder])
}

// Represents a size/variation (e.g., Small / Medium / Large)
model ItemVariant {
  id         String   @id @default(cuid())
  menuItemId String
  name       String   // e.g., "Small (6 Slice - 10 inch)"
  price      Float
  sortOrder  Int      @default(0)
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  menuItem       MenuItem        @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  modifierGroups ModifierGroup[]
}

// Modifier groups can be:
// - item-level:    menuItemId set, categoryId null, restaurantId null
// - variant-level: variantId set, menuItemId set
// - category-level: categoryId set, menuItemId null
// - library (reusable): restaurantId set, menuItemId null, categoryId null
model ModifierGroup {
  id            String   @id @default(cuid())
  restaurantId  String?  // null = item-scoped, set = library group
  menuItemId    String?
  variantId     String?
  categoryId    String?
  name          String
  description   String?
  required      Boolean  @default(false)
  minSelect     Int      @default(0)
  maxSelect     Int      @default(1)
  maxPerOption  Int      @default(1)  // how many times same option can be picked
  isHidden      Boolean  @default(false)
  sortOrder     Int      @default(0)
  libraryGroupId String? // if attached from a library group (points to the source library ModifierGroup id)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant Restaurant?  @relation(fields: [restaurantId], references: [id])
  menuItem   MenuItem?    @relation(fields: [menuItemId], references: [id])
  variant    ItemVariant? @relation(fields: [variantId], references: [id])
  category   MenuCategory? @relation(fields: [categoryId], references: [id])
  options    ModifierOption[]
}

model ModifierOption {
  id              String   @id @default(cuid())
  modifierGroupId String
  name            String
  priceAdjustment Float    @default(0)
  isDefault       Boolean  @default(false)
  isAvailable     Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  modifierGroup ModifierGroup       @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  orderItemMods OrderItemModifier[]
}

model Order {
  id               String   @id @default(cuid())
  restaurantId     String
  customerId       String?
  orderNumber      String
  status           String   @default("pending")
  type             String   @default("pickup")
  customerName     String
  customerEmail    String?
  customerPhone    String?
  deliveryAddress  String?
  deliveryCity     String?
  deliveryZip      String?
  notes            String?
  couponId         String?
  couponDiscount   Float    @default(0)
  promoDiscount    Float    @default(0)
  subtotal         Float
  taxAmount        Float    @default(0)
  deliveryFee      Float    @default(0)
  tip              Float    @default(0)
  total            Float
  paymentMethod    String   @default("cash")
  paymentStatus    String   @default("pending")
  paymentIntentId  String?
  refundStatus     String?   // null | "pending" | "refunded" | "failed"
  /// Set when the order has been "released" to the kitchen + customer
  /// (i.e. notifications fired, kitchen display picks it up). For cash
  /// orders this is set immediately in /api/orders POST. For online-card
  /// orders this stays null until the payment_intent.succeeded webhook
  /// fires — preventing the kitchen from starting cook before payment
  /// clears. Kitchen GET filters on `notifiedAt IS NOT NULL`.
  notifiedAt       DateTime?
  scheduledFor     DateTime?
  estimatedReady   DateTime?
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  completedAt      DateTime?
  preparationTime  Int?
  deliveryZoneId           String?
  deliveryEstimatedMinutes Int?
  appliedServiceFees String?  // JSON: [{ name, amount }] frozen at order time
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurant    Restaurant     @relation(fields: [restaurantId], references: [id])
  customer      Customer?      @relation(fields: [customerId], references: [id])
  coupon        Coupon?        @relation(fields: [couponId], references: [id])
  deliveryZone  DeliveryZone?  @relation(fields: [deliveryZoneId], references: [id])
  items         OrderItem[]

  @@index([restaurantId, createdAt])
  @@index([restaurantId, status])
  @@index([restaurantId, orderNumber])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String?
  variantId  String?
  variantName String?
  name       String
  price      Float
  quantity   Int
  notes      String?
  subtotal   Float
  createdAt  DateTime @default(now())

  order      Order               @relation(fields: [orderId], references: [id])
  menuItem   MenuItem?           @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
  modifiers  OrderItemModifier[]
}

model OrderItemModifier {
  id               String  @id @default(cuid())
  orderItemId      String
  modifierOptionId String? // nullable so deleting a modifier group doesn't break order history
  name             String
  priceAdjustment  Float   @default(0)

  orderItem      OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption ModifierOption? @relation(fields: [modifierOptionId], references: [id], onDelete: SetNull)
}

model Customer {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  email        String?
  phone        String?
  address      String?
  notes        String?
  totalOrders  Int      @default(0)
  totalSpent   Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]

  @@index([restaurantId])
  @@index([restaurantId, email])
}

model Coupon {
  id             String    @id @default(cuid())
  restaurantId   String
  code           String
  description    String?
  discountType   String    @default("percentage")
  discountValue  Float
  minimumOrder   Float     @default(0)
  maxUses        Int?
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]

  @@unique([restaurantId, code])
  @@index([restaurantId, isActive])
}

model Promotion {
  id            String    @id @default(cuid())
  restaurantId  String
  name          String
  description   String?
  promotionType String    @default("percentage_off")
  isActive      Boolean   @default(true)
  stackingRule  String    @default("standard")
  orderType     String    @default("both")
  customerType  String    @default("any")
  minimumOrder  Float     @default(0)
  rules         String    @default("{}")
  daysOfWeek    String?
  startsAt      DateTime?
  endsAt        DateTime?
  usageLimit    Int?
  usedCount     Int       @default(0)
  autoApply     Boolean   @default(true)
  couponCode    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, isActive])
}

model DeliveryZone {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  color        String   @default("#f97316")
  centerLat    Float    @default(0)
  centerLng    Float    @default(0)
  radiusKm     Float    @default(5)
  deliveryFee  Float    @default(0)
  minimumOrder Float    @default(0)
  estimatedMinutes Int  @default(30)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  orders     Order[]

  @@index([restaurantId])
}

model OpeningHours {
  id           String  @id @default(cuid())
  restaurantId String
  dayOfWeek    Int
  isOpen       Boolean @default(true)
  openTime     String  @default("09:00")
  closeTime    String  @default("21:00")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, dayOfWeek])
}

model ReceiptTemplate {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  type         String   @default("customer")
  template     String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

model PrinterSettings {
  id                   String   @id @default(cuid())
  restaurantId         String   @unique
  // PrintNode credentials (AES-256-GCM encrypted)
  printNodeApiKeyEnc   String?
  printNodeApiKeyIv    String?
  printNodeApiKeyTag   String?
  printNodeConnected   Boolean  @default(false)
  printNodeAccountName String?
  selectedPrinterId    Int?     // PrintNode printer ID
  selectedPrinterName  String?  // Cached printer display name
  // Print options
  autoPrint            Boolean  @default(false)
  printKitchen         Boolean  @default(true)
  printCustomer        Boolean  @default(true)
  kitchenCopies        Int      @default(1)
  customerCopies       Int      @default(1)
  paperWidth           String   @default("80mm")
  fontSize             String   @default("normal")
  showLargeOrderNumber Boolean  @default(true)
  showLogo             Boolean  @default(false)
  printerLanguage      String   @default("escpos") // escpos | starprnt | plaintext
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

model PrintLog {
  id             String   @id @default(cuid())
  restaurantId   String
  orderId        String?
  orderNumber    String?
  receiptType    String           // kitchen | customer | test
  printerName    String?
  printNodeJobId BigInt?  // PrintNode job IDs have outgrown int32; BigInt is safe
  status         String   @default("sent") // sent | failed
  errorMessage   String?
  createdAt      DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, createdAt])
}

model AutopilotCampaign {
  id           String   @id @default(cuid())
  restaurantId String
  campaignType String   // second_order | cart_abandonment | reengagement
  isEnabled    Boolean  @default(false)
  subject      String   @default("")
  emailBody    String   @default("")
  delayHours   Int      @default(24)
  couponId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([restaurantId, campaignType])
}

model ReservationSettings {
  id                   String   @id @default(cuid())
  restaurantId         String   @unique
  minNoticeHours       Int      @default(2)
  maxAdvanceDays       Int      @default(30)
  slotLengthMinutes    Int      @default(30)
  maxPerSlot           Int      @default(10)
  minGuests            Int      @default(1)
  maxGuests            Int      @default(20)
  autoConfirm          Boolean  @default(true)
  allowPreOrder        Boolean  @default(false)
  holdMinutes          Int      @default(15)
  requireDeposit       Boolean  @default(false)
  depositAmount        Float    @default(0)
  cancellationPolicy   String   @default("")
  reservationHours     String   @default("{}") // JSON: { "0": { open: "10:00", close: "22:00", enabled: true } }
  blackoutDates        String   @default("[]") // JSON: ["2024-12-25"]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

model ReservationTable {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  number       Int?
  section      String?
  capacity     Int      @default(4)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  restaurant   Restaurant    @relation(fields: [restaurantId], references: [id])
  reservations Reservation[]

  @@index([restaurantId])
}

model Reservation {
  id               String   @id @default(cuid())
  restaurantId     String
  tableId          String?
  orderId          String?
  confirmationCode String
  status           String   @default("pending") // pending | confirmed | seated | completed | cancelled | no_show
  customerName     String
  customerEmail    String?
  customerPhone    String?
  partySize        Int
  date             String   // "YYYY-MM-DD"
  time             String   // "HH:MM"
  durationMinutes  Int      @default(90)
  notes            String?
  staffNotes       String?
  depositAmount    Float    @default(0)
  depositPaid      Boolean  @default(false)
  preOrderTotal    Float    @default(0)
  paymentIntentId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurant Restaurant        @relation(fields: [restaurantId], references: [id])
  table      ReservationTable? @relation(fields: [tableId], references: [id])

  @@index([restaurantId, date])
  @@index([restaurantId, status])
}

model ServiceFee {
  id                 String   @id @default(cuid())
  restaurantId       String
  name               String
  feeType            String   // "fixed" | "percent"
  amount             Float
  appliesTo          String   @default("both")  // "pickup" | "delivery" | "both"
  daysOfWeek         String?  // CSV "0,5,6" — null = every day
  publicHolidaysOnly Boolean  @default(false)
  countryCode        String   @default("US")
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model PaymentProvider {
  id                String   @id @default(cuid())
  restaurantId      String   @unique
  provider          String   @default("stripe")      // stripe
  mode              String   @default("test")         // test | live
  publishableKey    String   @default("")
  secretKeyEnc      String   @default("")             // AES-256-GCM encrypted
  secretKeyIv       String   @default("")
  secretKeyTag      String   @default("")
  isActive          Boolean  @default(false)
  connectMethod     String   @default("direct")       // direct | connect
  stripeAccountId   String?
  lastTestedAt      DateTime?
  lastTestStatus    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}

// ─── Reseller Partner Program ──────────────────────────────────────────────
//
// One ResellerProfile per reseller_partner user. Status drives whether they
// can log in / earn commission. The referralCode is appended to signup URLs
// (/signup?ref=<code>) so attribution is set at restaurant creation time —
// see src/app/api/auth/register/route.ts.
model ResellerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Application + approval lifecycle
  status            String   @default("pending") // pending | approved | suspended | rejected
  companyName       String?
  website           String?
  country           String?
  applicationNotes  String?  // what they wrote on the application form
  approvedAt        DateTime?
  approvedBy        String?  // superadmin User.id
  suspendedAt       DateTime?
  suspendedReason   String?

  // Payout preferences. Money is sent manually by the superadmin per the
  // chosen method; payoutDetails is an encrypted JSON blob (PayPal email,
  // bank routing info, etc.) using the same AES-GCM envelope as Stripe keys.
  payoutMethod      String?
  payoutDetails     String?
  payoutDetailsIv   String?
  payoutDetailsTag  String?

  referralCode      String   @unique @default(cuid())
  totalEarnedCents  Int      @default(0) // lifetime gross
  totalPaidCents    Int      @default(0) // lifetime payouts marked paid

  // Superadmin can pin a custom flat rate that overrides the default tier
  // table (0/5/10%). When non-null, recordCommissionForInvoice uses this
  // value regardless of active-paying count. Useful for VIP partners.
  customCommissionRate Float?   // percent, e.g. 7 means 7%

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  restaurants Restaurant[]
  commissions CommissionTransaction[]
  payouts     PayoutRequest[]

  @@index([status])
  @@index([referralCode])
}

// Many-to-many between User and Restaurant for non-owner access. The owning
// restaurant_admin uses User.restaurantId; everything else (reseller managers,
// shared staff, future delegation) goes here. accessRole bounds what they can
// do at the route level.
model RestaurantAccess {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  accessRole   String   // owner | reseller_manager | manager | staff | readonly
  grantedBy    String?  // user id of who granted this access
  grantedAt    DateTime @default(now())

  @@unique([userId, restaurantId])
  @@index([restaurantId])
}

// One row per SubscriptionInvoice that earns commission for a reseller.
// Idempotent by subscriptionInvoiceId unique. The snapshot fields
// (activePayingCount, ratePercent, netRevenueCents) are frozen at recording
// time so we can audit how each amount was derived.
model CommissionTransaction {
  id                    String   @id @default(cuid())
  resellerProfileId     String
  resellerProfile       ResellerProfile @relation(fields: [resellerProfileId], references: [id], onDelete: Cascade)
  restaurantId          String
  restaurant            Restaurant @relation(fields: [restaurantId], references: [id])
  subscriptionInvoiceId String   @unique
  subscriptionInvoice   SubscriptionInvoice @relation(fields: [subscriptionInvoiceId], references: [id])

  netRevenueCents       Int
  activePayingCount     Int
  ratePercent           Float
  commissionCents       Int

  status            String   @default("pending") // pending | available | paid | reversed
  reversedAt        DateTime?
  reversedReason    String?
  payoutRequestId   String?
  payoutRequest     PayoutRequest? @relation(fields: [payoutRequestId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([resellerProfileId, status])
  @@index([restaurantId])
}

// A reseller's request to be paid out. Includes one or more commissions.
// Superadmin approves and then marks paid after sending money out-of-band.
model PayoutRequest {
  id                String   @id @default(cuid())
  resellerProfileId String
  resellerProfile   ResellerProfile @relation(fields: [resellerProfileId], references: [id], onDelete: Cascade)

  amountCents       Int
  currency          String   @default("usd")
  status            String   @default("requested") // requested | approved | paid | rejected | cancelled
  requestedAt       DateTime @default(now())
  approvedAt        DateTime?
  approvedBy        String?
  paidAt            DateTime?
  paidBy            String?
  rejectedAt        DateTime?
  rejectedReason    String?

  payoutReference   String?
  notes             String?

  commissions       CommissionTransaction[]

  @@index([resellerProfileId, status])
}

// ─── Phase 1: Add-on catalog + per-restaurant subscriptions ────────────────
//
// We're decoupling "plan" (free for everyone going forward) from "add-ons"
// (individual feature unlocks billed independently). The old SubscriptionPlan
// model stays as-is for backward compatibility; new signups land on a Free
// plan there. AddOn is a flat catalog of features owners can subscribe to,
// each with its own Stripe Price.

model AddOn {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  monthlyPriceCents  Int   @default(0)
  yearlyPriceCents   Int?
  trialDays       Int?
  isActive        Boolean  @default(true)
  displayOrder    Int      @default(0)
  /// JSON-encoded array of feature slugs this add-on unlocks. e.g.
  /// `["card_payments","stripe_connect"]` for online_payments. Keeping this
  /// as a JSON string instead of a relation table keeps Phase 1 simple; we
  /// can split to a relation later if the list gets unwieldy.
  enabledFeatures String   @default("[]")
  /// JSON-encoded array of other add-on slugs that must be active for this
  /// to work (e.g. custom_domain requires hosted_website).
  requiredDependencies String @default("[]")
  /// Stripe wiring — populated when the superadmin syncs an add-on (Phase 5).
  stripePriceId   String?  @unique
  stripeProductId String?  @unique

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  restaurantAddOns RestaurantAddOn[]

  @@index([slug])
}

model RestaurantAddOn {
  id              String   @id @default(cuid())
  restaurantId    String
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  addOnId         String
  addOn           AddOn    @relation(fields: [addOnId], references: [id])

  status          String   @default("active") // active | trialing | past_due | cancelled | incomplete
  stripeSubscriptionId String?  @unique
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  trialEndsAt     DateTime?
  activatedAt     DateTime @default(now())

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([restaurantId, addOnId])
  @@index([restaurantId])
  @@index([status])
}

