# Copy this file to `.env` and fill in your own values.
# .env itself is gitignored — never commit it.

# ── Database (SQLite for local dev) ───────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a fresh secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# ── Stripe (test keys from https://dashboard.stripe.com/test/apikeys) ────────
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get an API key at https://resend.com (3000 emails/month free tier).
# Without a key, all email helpers log to the console instead of sending.
RESEND_API_KEY=""
EMAIL_FROM="Fee Free Ordering <onboarding@resend.dev>"
# (Legacy fields, still read by some places — leave empty if using Resend)
EMAIL_SERVER=""

# ── AES-256-GCM key for encrypting Stripe secret keys at rest ────────────────
# REQUIRED for online payments. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ── Google Maps (optional) ────────────────────────────────────────────────────
# Map provider is now configured per-restaurant in Admin → Map Settings.
# This env var is only used as a legacy fallback and can stay empty.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
