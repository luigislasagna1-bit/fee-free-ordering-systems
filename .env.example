# ─────────────────────────────────────────────────────────────────────────────
# Fee Free Ordering Systems — environment template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values. Real secrets belong in
# `.env.local` (also git-ignored) which overrides `.env` at runtime.
#
# Quick setup for a fresh clone:
#   1. cp .env.example .env
#   2. Create a Neon Postgres project at https://neon.tech (free tier is plenty)
#      → copy the direct connection string and paste it as DATABASE_URL below
#      → or into .env.local for the strongest separation
#   3. Generate ENCRYPTION_KEY (one-time):
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   4. Generate NEXTAUTH_SECRET (one-time):
#        node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   5. npx prisma db push       # creates the Postgres schema in your Neon DB
#   6. npm run seed             # creates Pizza Palace demo + dev accounts
#   7. npm run dev              # http://localhost:3001
# ─────────────────────────────────────────────────────────────────────────────


# ── Postgres ────────────────────────────────────────────────────────────────
# Neon, Supabase, Vercel Postgres, or any other Postgres host works. Must be
# the DIRECT (unpooled) connection string — Prisma migrations need it.
# Example: postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"


# ── NextAuth ────────────────────────────────────────────────────────────────
# 32+ random bytes. NEVER commit a real value — regenerate per environment.
NEXTAUTH_SECRET="change-me-generate-with-crypto-randomBytes"

# Public URL the app is reached at. Local dev = localhost:3001. For phone-
# testing via cloudflared/ngrok tunnel, override in .env.local. In production,
# set to your real domain via your deploy host's env config.
NEXTAUTH_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"


# ── Stripe (optional — only if testing/processing card payments) ────────────
# Set up a Stripe Connect application at https://dashboard.stripe.com
# Test mode keys are fine for development.
STRIPE_SECRET_KEY="sk_test_placeholder"
STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
STRIPE_WEBHOOK_SECRET="whsec_placeholder"


# ── Email ──────────────────────────────────────────────────────────────────
# Primary path: Resend (https://resend.com, 3000 emails/month free).
# Leave RESEND_API_KEY empty in dev to make all email helpers log to console
# instead of sending. EMAIL_SERVER is a legacy fallback (SMTP URL).
RESEND_API_KEY=""
EMAIL_FROM="Fee Free Ordering <onboarding@resend.dev>"
EMAIL_SERVER=""


# ── Encryption (REQUIRED if any restaurant connects Stripe) ────────────────
# AES-256-GCM key used to encrypt per-restaurant Stripe secret keys at rest.
# Once set, NEVER change it without re-encrypting existing rows. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-32-bytes-hex-encoded"


# ── Google Maps (optional — better address autocomplete + maps) ────────────
# Free tier covers small dev usage. Restrict the key to your domains in the
# Google Cloud Console once you have a real domain.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""


# ── Multi-tenant routing ───────────────────────────────────────────────────
# Subdomains under PLATFORM_DOMAIN route to the matching restaurant. In dev
# use `localtest.me` — its public DNS resolves all subdomains to 127.0.0.1 so
# you can test multi-tenant routing without editing /etc/hosts.
# In production this is your actual platform domain (e.g. feefreeordering.com).
PLATFORM_DOMAIN=localtest.me

# Marketplace domain (optional). When set, requests to this domain are
# host-routed to the marketplace experience: "/" rewrites to /marketplace,
# admin/auth paths 301 back to PLATFORM_DOMAIN, customer-facing paths
# (/marketplace/*, /order/*, /api/*) passthrough so the entire ordering
# journey stays on this brand. Leave blank in dev; set to feefreefood.com
# in prod once DNS is wired.
MARKETPLACE_DOMAIN=

# Domain provider integration. `local` is a dev stub. In production set to
# `vercel` (requires VERCEL_TOKEN + VERCEL_PROJECT_ID) when you want the admin
# UI to actually register tenant custom domains via the Vercel API.
DOMAIN_PROVIDER=local
# VERCEL_TOKEN=""
# VERCEL_PROJECT_ID=""
# VERCEL_TEAM_ID=""

# Internal API secret (used by the host-resolver route in prod).
# Generate with the same crypto.randomBytes recipe as NEXTAUTH_SECRET.
# INTERNAL_API_SECRET=""


# ── Sentry (error monitoring) ────────────────────────────────────────────────
# Sign up free at https://sentry.io — the free tier includes 5K errors and
# 10K performance events per month, plenty for soft launch. Create a new
# Next.js project in Sentry; it'll give you a DSN. Set BOTH the public and
# server vars below — they hold the same DSN value (Sentry's SDK pulls
# them from different bundles).
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# Sourcemap upload (optional but strongly recommended in prod). Without
# these, stack traces in the Sentry UI show transpiled/minified code. With
# them, traces map back to your TypeScript source.
#   - SENTRY_AUTH_TOKEN: https://sentry.io/settings/account/api/auth-tokens/
#     scope it to `project:releases` only
#   - SENTRY_ORG: your Sentry org slug (e.g. "feefree")
#   - SENTRY_PROJECT: your Sentry project slug (e.g. "fee-free-ordering")
# All three only matter at BUILD time (CI / Vercel). Locally you can leave
# them blank — Sentry's webpack plugin will skip the upload step silently.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── ShipDay driver pool (optional, restaurant-specific) ─────────────────────
# ShipDay API credentials are stored PER-RESTAURANT in ShipdayConfig
# (encrypted with ENCRYPTION_KEY). No platform-level API key needed.
#
# The webhook receiver at /api/webhooks/shipday DOES need a shared secret
# so randoms can't fake status callbacks. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then paste the same value into ShipDay Dashboard → Webhooks → Token.
# When unset, the webhook accepts any caller and logs a warning.
SHIPDAY_WEBHOOK_TOKEN=""


# Force Sentry to capture events in non-production environments. Off by
# default — local dev + preview deploys would otherwise spam the issue
# queue with every reload error. Set to "1" when debugging a server-side
# capture flow locally.
# SENTRY_FORCE_ENABLE=0
# NEXT_PUBLIC_SENTRY_FORCE_ENABLE=0
