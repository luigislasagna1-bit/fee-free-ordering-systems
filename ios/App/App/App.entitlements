<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Native push for the order alarm (Luigi 2026-07-04). "production" is
	     correct for both TestFlight and App Store distribution builds.
	     REQUIRES the Push Notifications capability to be enabled on the
	     com.feefreeordering.kitchen App ID in the Apple Developer portal
	     BEFORE the next Codemagic build, or profile signing fails. -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- Order alarms must ring through Sleep/DND Focus — Luigi's locked-phone
	     test failed silently at 12:30 AM because default Sleep Focus swallowed
	     the push (2026-07-05). push.ts already sends interruption-level
	     time-sensitive; this entitlement stops iOS downgrading it. Enable the
	     "Time Sensitive Notifications" capability on the App ID first. -->
	<key>com.apple.developer.usernotifications.time-sensitive</key>
	<true/>
</dict>
</plist>
