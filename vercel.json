{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/commissions",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/marketplace-settle",
      "schedule": "5 0 1 * *"
    },
    {
      "path": "/api/cron/auto-reject-stale-orders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/autopilot",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/auto-complete-orders",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/cron/reports-snapshot",
      "schedule": "0 3 * * *"
    }
  ]
}
