<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Push: replace the Capacitor plugin's messaging service with ours so
             we can fire the loud order alarm. Ours EXTENDS the plugin's, so its
             JS delivery + token handling are preserved. Luigi 2026-06-15. -->
        <service
            android:name="com.capacitorjs.plugins.pushnotifications.MessagingService"
            tools:node="remove" />
        <service
            android:name=".KitchenMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Loud looping "new order" alarm — plays even with the app
             backgrounded / screen off. mediaPlayback because it plays the order
             ring on the alarm stream. -->
        <service
            android:name=".OrderAlarmService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Always-on keep-alive so Android never app-standby / deep-sleep
             throttles the order alarm push. Luigi 2026-06-16. -->
        <service
            android:name=".KitchenKeepAliveService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Keeps the kitchen order app connected so new-order alerts ring in real time, even with the screen off." />
        </service>

        <!-- Doze-proof heartbeat (K1): an exact-while-idle AlarmManager beat re-asserts the
             keep-alive poll even after aggressive OEMs kill it in deep sleep. Triggered by
             an explicit PendingIntent, so no intent-filter is needed. Luigi 2026-06-23. -->
        <receiver
            android:name=".HeartbeatReceiver"
            android:exported="false" />

        <!-- Re-arm the keep-alive + heartbeat after a reboot (kitchen tablets reboot on
             power blips) so orders ring without someone opening the app first. -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required for the DirectPrinter plugin's mDNS discovery
         (NsdManager filtered by the system without a multicast
         lock) AND for the subnet-scan fallback that walks the local
         /24 looking for port-9100 responders. -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Push notifications + the loud full-screen order alarm. Luigi 2026-06-15. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Lets the app prompt the owner (one tap) to exempt it from battery
         optimization, so Android doesn't sleep it and drop the new-order alarm
         push when the screen is off. Luigi 2026-06-16. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Boot receiver: re-arm the keep-alive + heartbeat after a reboot. Luigi 2026-06-23. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- NOTE: we deliberately declare NO exact-alarm permission (USE_EXACT_ALARM /
         SCHEDULE_EXACT_ALARM). Google Play restricts those to alarm-clock-class apps and could
         flag/reject this restaurant app at review. The heartbeat uses an EXACT while-idle alarm
         only on pre-API-31 (e.g. the Samsung A10 target, where it needs no permission) and falls
         back to an INEXACT while-idle alarm on API 31+ (also no permission). See HeartbeatReceiver. -->
</manifest>
